      {"@type": "Question", "name": "Do you buy houses with tenants?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. We buy rental properties with tenants in place. No need to evict anyone before selling."}},
      {"@type": "Question", "name": "What areas do you serve?", "acceptedAnswer": {"@type": "Answer", "text": "Wichita, Derby, Mulvane, Haysville, Andover, Augusta, El Dorado, Park City, Bel Aire, Valley Center, Goddard, Maize, and all of Sedgwick County KS."}}
