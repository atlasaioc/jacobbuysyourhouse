      {"@type": "Question", "name": "Is the cash offer actually fair?", "acceptedAnswer": {"@type": "Answer", "text": "We base offers on real Wichita market data. We won't insult you with a lowball number. If it doesn't work, no hard feelings."}},
      {"@type": "Question", "name": "Are there any fees or commissions?", "acceptedAnswer": {"@type": "Answer", "text": "None. What we offer is what you receive — no deductions, no surprises at closing."}},
