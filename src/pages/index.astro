---
import Base from '../layouts/Base.astro';
---
<Base
  title="Sell Your House Fast in Wichita KS | Jacob Buys Your House"
  description="Jacob Matlock buys houses for cash in Wichita KS. Fair offer in 24 hours, close in 7 days. No repairs, no fees, no hassle. Call (316) 368-3344."
>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "RealEstateAgent",
    "name": "Jacob Buys Your House",
    "url": "https://jacobbuysyourhouse.com",
    "telephone": "+13163683344",
    "address": { "@type": "PostalAddress", "addressLocality": "Wichita", "addressRegion": "KS", "addressCountry": "US" },
    "areaServed": ["Wichita","Derby","Mulvane","Haysville","Andover","Augusta","El Dorado"],
    "openingHours": "Mo-Su 08:00-20:00"
  }
  </script>

  <style>
    /* ─── HERO ─── */
    .hero {
      background: #3aa1f8;
      min-height: 580px;
      display: flex;
      align-items: center;
      padding: 80px 0;
      position: relative;
      overflow: hidden;
    }
    /* subtle radial glow like eric's site */
    .hero::before {
      content: '';
      position: absolute;
      top: -40%;
      right: -15%;
      width: 700px;
      height: 700px;
      background: radial-gradient(circle, rgba(255,255,255,.12) 0%, transparent 65%);
      pointer-events: none;
    }
    .hero::after {
      content: '';
      position: absolute;
      bottom: -30%;
      left: -10%;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(26,130,216,.5) 0%, transparent 60%);
      pointer-events: none;
    }
    .hero-content { position: relative; z-index: 2; color: white; text-align: center; }
    .hero-eyebrow {
      display: inline-block;
      background: rgba(255,255,255,.18);
      border: 1px solid rgba(255,255,255,.3);
      color: white;
      font-size: 12px; font-weight: 700;
      letter-spacing: 2px; text-transform: uppercase;
      padding: 7px 20px; border-radius: 100px;
      margin-bottom: 24px;
    }
    .hero h1 {
      font-size: clamp(2.6rem, 5.5vw, 4rem);
      font-weight: 900; line-height: 1.1;
      margin-bottom: 16px;
      letter-spacing: -1.5px;
      color: white;
    }
    .hero-sub {
      font-size: 19px;
      color: rgba(255,255,255,.92);
      margin-bottom: 16px;
      max-width: 580px;
      margin-left: auto; margin-right: auto;
      line-height: 1.6;
    }
    .hero-tagline {
      font-size: 15px;
      color: rgba(255,255,255,.8);
      margin-bottom: 40px;
      font-weight: 600;
      letter-spacing: .3px;
    }
    .hero-tagline strong { color: white; }
    .hero-cta {
      display: flex; gap: 14px; justify-content: center;
      flex-wrap: wrap; margin-bottom: 48px;
    }
    .btn-hero-primary {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--orange); color: white;
      font-weight: 800; font-size: 17px;
      padding: 18px 44px; border-radius: 8px;
      text-decoration: none;
      box-shadow: 0 6px 24px rgba(232,113,34,.55);
      transition: all .2s;
      white-space: nowrap;
    }
    .btn-hero-primary:hover { background: var(--orange-dark); color: white; transform: translateY(-2px); box-shadow: 0 8px 32px rgba(232,113,34,.65); }
    .btn-hero-secondary {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(255,255,255,.16);
      border: 2px solid rgba(255,255,255,.5);
      color: white; font-weight: 600; font-size: 16px;
      padding: 16px 36px; border-radius: 8px;
      text-decoration: none; transition: all .2s;
      white-space: nowrap;
    }
    .btn-hero-secondary:hover { background: rgba(255,255,255,.28); color: white; }
    .hero-phone {
      font-size: 20px; font-weight: 800; color: white;
      letter-spacing: .3px; margin-bottom: 36px;
    }
    .hero-phone a { color: var(--orange); text-decoration: none; }
    .hero-phone a:hover { color: #ffd0a0; }
    .trust-row { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .trust-chip {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(255,255,255,.14);
      border: 1px solid rgba(255,255,255,.25);
      color: white; font-size: 13px; font-weight: 600;
      padding: 8px 16px; border-radius: 100px;
    }

    /* ─── STATS BAR ─── */
    .stats-bar { background: #1d1d1d; padding: 0; border-top: 4px solid var(--orange); }
    .stats-inner { display: grid; grid-template-columns: repeat(4,1fr); }
    .stat-item {
      text-align: center; padding: 28px 20px;
      border-right: 1px solid rgba(255,255,255,.08);
    }
    .stat-item:last-child { border-right: none; }
    .stat-num { font-size: 2.2rem; font-weight: 900; color: var(--blue); line-height: 1; margin-bottom: 5px; }
    .stat-label { font-size: 11.5px; color: rgba(255,255,255,.55); text-transform: uppercase; letter-spacing: 1.2px; font-weight: 600; }

    /* ─── HOW IT WORKS ─── */
    .step-card {
      background: white; border: 1px solid var(--border);
      border-radius: 18px; padding: 36px 28px;
      text-align: center;
      box-shadow: 0 2px 16px rgba(58,161,248,.08);
      transition: all .2s;
    }
    .step-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(58,161,248,.18); border-color: var(--blue-mid); }
    .step-num {
      width: 60px; height: 60px;
      background: var(--blue); color: white;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.6rem; font-weight: 900;
      margin: 0 auto 20px;
      box-shadow: 0 4px 16px rgba(58,161,248,.4);
    }
    .step-card h3 { font-size: 1.05rem; font-weight: 700; color: var(--text); margin-bottom: 10px; }
    .step-card p { font-size: 14.5px; color: var(--text-light); line-height: 1.65; }

    /* ─── ANY SECTION (blue background) ─── */
    .any-section { background: var(--blue); padding: 88px 0; }
    .any-card {
      background: white; border-radius: 18px;
      padding: 36px 30px;
      box-shadow: 0 4px 24px rgba(0,0,0,.15);
    }
    .any-icon { font-size: 2rem; margin-bottom: 14px; }
    .any-card h3 { font-size: 1.1rem; font-weight: 800; color: var(--blue-dark); margin-bottom: 18px; }
    .any-list { list-style: none; }
    .any-list li { padding: 9px 0 9px 24px; position: relative; font-size: 14.5px; color: #444; border-bottom: 1px solid #f0f4f8; }
    .any-list li:last-child { border: none; padding-bottom: 0; }
    .any-list li::before { content: "✓"; position: absolute; left: 0; color: var(--blue); font-weight: 800; }

    /* ─── COMPARISON ─── */
    .compare-wrap { overflow-x: auto; margin-top: 48px; }
    .compare-table { width: 100%; border-collapse: separate; border-spacing: 0; border-radius: 16px; overflow: hidden; box-shadow: 0 2px 24px rgba(58,161,248,.12); }
    .compare-table th { padding: 20px 24px; font-size: 14px; font-weight: 700; text-align: center; }
    .compare-table th:first-child { text-align: left; background: var(--gray-light); color: var(--gray); width: 36%; }
    .th-us { background: var(--blue) !important; color: white; }
    .th-them { background: #ebebeb !important; color: #888; }
    .compare-table td { padding: 15px 24px; font-size: 14.5px; text-align: center; }
    .compare-table td:first-child { text-align: left; font-weight: 600; color: #333; background: #fafafa; }
    .compare-table tr:nth-child(even) td { background: #f7fbff; }
    .compare-table tr:nth-child(even) td:first-child { background: #f3f5f8; }
    .check { color: #1a9a4a; font-weight: 700; }
    .cross { color: #cc2222; font-weight: 700; }

    /* ─── WHY JACOB (blue bg) ─── */
    .jacob-section { background: var(--blue); padding: 88px 0; }
    .jacob-text-col {}
    .stat-glass {
      background: rgba(255,255,255,.18);
      border: 1px solid rgba(255,255,255,.3);
      border-radius: 16px; padding: 28px;
      text-align: center;
    }
    .stat-glass .num { font-size: 2.4rem; font-weight: 900; color: white; line-height: 1; margin-bottom: 4px; }
    .stat-glass .lbl { font-size: 11.5px; color: rgba(255,255,255,.75); text-transform: uppercase; letter-spacing: 1.2px; font-weight: 600; }

    /* ─── AREAS ─── */
    .area-chip { background: white; border: 1.5px solid var(--blue-mid); color: var(--blue-dark); font-weight: 700; font-size: 13.5px; padding: 12px 16px; border-radius: 10px; text-decoration: none; text-align: center; display: block; transition: all .15s; }
    .area-chip:hover { background: var(--blue); color: white; border-color: var(--blue); transform: translateY(-1px); box-shadow: 0 4px 14px rgba(58,161,248,.35); }

    /* ─── FAQ ─── */
    .faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; max-width: 900px; margin: 48px auto 0; }
    .faq-item { background: white; border: 1px solid var(--border); border-radius: 12px; padding: 24px 28px; border-top: 3px solid var(--blue); transition: box-shadow .15s; }
    .faq-item:hover { box-shadow: 0 4px 20px rgba(58,161,248,.12); }
    .faq-item h3 { font-size: 15px; font-weight: 700; color: var(--blue-dark); margin-bottom: 10px; }
    .faq-item p { font-size: 14.5px; color: var(--text-light); margin: 0; line-height: 1.65; }

    /* ─── CTA SECTION ─── */
    .cta-section { background: var(--orange); padding: 88px 0; text-align: center; position: relative; overflow: hidden; }
    .cta-section::before { content: ''; position: absolute; top: -50%; right: -10%; width: 600px; height: 600px; background: radial-gradient(circle, rgba(255,255,255,.12) 0%, transparent 60%); pointer-events: none; }
    .cta-section h2 { font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 900; color: white; margin-bottom: 14px; letter-spacing: -1px; position: relative; }
    .cta-section p { font-size: 18px; color: rgba(255,255,255,.88); margin-bottom: 40px; position: relative; }
    .btn-cta { display: inline-flex; align-items: center; gap: 8px; background: white; color: var(--orange); font-weight: 800; font-size: 17px; padding: 18px 48px; border-radius: 8px; text-decoration: none; transition: all .2s; box-shadow: 0 4px 20px rgba(0,0,0,.15); position: relative; }
    .btn-cta:hover { background: #1d1d1d; color: white; transform: translateY(-2px); box-shadow: 0 6px 28px rgba(0,0,0,.2); }


    /* ─── CITY CARDS ─── */
    .city-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    .city-card { display: block; border-radius: 14px; overflow: hidden; text-decoration: none; box-shadow: 0 2px 12px rgba(58,161,248,.1); transition: all .2s; border: 1px solid var(--border); }
    .city-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(58,161,248,.2); }
    .city-img { height: 160px; background-size: cover; background-position: center; position: relative; }
    .city-img::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,.55) 100%); }
    .city-label { background: white; padding: 14px 16px; font-weight: 700; font-size: 15px; color: var(--blue-dark); display: flex; align-items: center; justify-content: space-between; }
    .city-label::after { content: '→'; color: var(--blue); font-size: 14px; }

    @media(max-width: 900px) { .city-grid { grid-template-columns: repeat(3, 1fr); } }
    @media(max-width: 600px) { .city-grid { grid-template-columns: repeat(2, 1fr); } }

    /* ─── FORM SECTION ─── */
    .form-section { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
    .form-bullets { list-style: none; margin-top: 24px; }
    .form-bullets li { color: rgba(255,255,255,.9); font-size: 15px; font-weight: 600; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,.12); }
    .form-bullets li:last-child { border: none; }
    .form-right { }
    .form-placeholder { background: white; border-radius: 16px; padding: 48px 40px; box-shadow: 0 8px 40px rgba(0,0,0,.2); min-height: 280px; display: flex; flex-direction: column; justify-content: center; }

    @media(max-width: 768px) { .form-section { grid-template-columns: 1fr; gap: 40px; } }

    @media(max-width: 640px) {
      .stats-inner { grid-template-columns: repeat(2,1fr); }
      .stat-item:nth-child(2) { border-right: none; }
      .stat-item:nth-child(3) { border-top: 1px solid rgba(255,255,255,.08); }
      .faq-grid { grid-template-columns: 1fr; }
      .hero-cta { flex-direction: column; align-items: center; }
    }
  </style>

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="container hero-content">
      <div class="hero-eyebrow">✦ Wichita's Trusted Local Cash Home Buyer</div>
      <h1>Get A Fair Offer<br/>On Your Home.</h1>
      <p class="hero-sub">No Fees. No Commissions. Put More Cash In Your Pocket.</p>
      <p class="hero-tagline"><strong>You Choose The Closing Date.</strong> We Pay All Costs!</p>
      <div class="hero-cta">
        <a href="tel:3163683344" class="btn-hero-primary">📞 Call (316) 368-3344</a>
        <a href="/contact" class="btn-hero-secondary">Get a Cash Offer →</a>
      </div>
      <div class="trust-row">
        <div class="trust-chip">⭐⭐⭐⭐⭐ Google Reviews</div>
        <div class="trust-chip">✅ No Fees or Commissions</div>
        <div class="trust-chip">⚡ Offer in 24 Hours</div>
        <div class="trust-chip">🏠 Close in 7 Days</div>
      </div>
    </div>
  </section>

  <!-- ═══ STATS BAR ═══ -->
  <div class="stats-bar">
    <div class="container">
      <div class="stats-inner">
        <div class="stat-item"><div class="stat-num">24hr</div><div class="stat-label">Cash Offer</div></div>
        <div class="stat-item"><div class="stat-num">7 Days</div><div class="stat-label">To Close</div></div>
        <div class="stat-item"><div class="stat-num">$0</div><div class="stat-label">Fees & Commissions</div></div>
        <div class="stat-item"><div class="stat-num">100%</div><div class="stat-label">As-Is — No Repairs</div></div>
      </div>
    </div>
  </div>

  <!-- ═══ HOW IT WORKS ═══ -->
  <section class="section bg-light">
    <div class="container">
      <div class="text-center" style="margin-bottom:48px">
        <span class="eyebrow">Simple Process</span>
        <h2 class="section-title">How It Works</h2>
        <p class="section-sub">Three steps. Zero hassle. We handle the paperwork so you can focus on what's next.</p>
      </div>
      <div class="grid-3">
        <div class="step-card">
          <div class="step-num">1</div>
          <h3>Tell Us About Your Home</h3>
          <p>Call, text, or fill out a quick form. Takes less than 5 minutes — no obligation whatsoever.</p>
        </div>
        <div class="step-card">
          <div class="step-num">2</div>
          <h3>Receive a Fair Cash Offer</h3>
          <p>We assess your property and deliver a real cash offer within 24 hours — based on actual Wichita market data.</p>
        </div>
        <div class="step-card">
          <div class="step-num">3</div>
          <h3>Pick Your Closing Date</h3>
          <p>Accept the offer and choose a date that works for you — as fast as 7 days or as far out as you need.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ANY REASON / CONDITION / CHALLENGE (Blue BG) ═══ -->
  <section class="any-section">
    <div class="container">
      <div class="text-center" style="margin-bottom:48px">
        <span class="eyebrow" style="color:rgba(255,255,255,.7)">We Handle It All</span>
        <h2 class="section-title section-title-white">We Buy Houses in Any Situation</h2>
        <p class="section-sub section-sub-white">Whatever brought you here — there's a path forward. We've seen it all.</p>
      </div>
      <div class="grid-3">
        <div class="any-card">
          <div class="any-icon">🏡</div>
          <h3>Any Reason</h3>
          <ul class="any-list">
            <li>Inherited Property</li>
            <li>Facing Foreclosure</li>
            <li>Going Through Divorce</li>
            <li>Tired Landlord</li>
            <li>Relocating for Work</li>
            <li>Downsizing</li>
            <li>Bankruptcy</li>
            <li>Health Issues</li>
          </ul>
        </div>
        <div class="any-card">
          <div class="any-icon">🔨</div>
          <h3>Any Condition</h3>
          <ul class="any-list">
            <li>Major Repairs Needed</li>
            <li>Fire or Storm Damage</li>
            <li>Full of Stuff or Trash</li>
            <li>Problem Tenants</li>
            <li>Foundation Issues</li>
            <li>Old &amp; Outdated</li>
            <li>Hoarder Home</li>
            <li>Unfinished Construction</li>
          </ul>
        </div>
        <div class="any-card">
          <div class="any-icon">⚡</div>
          <h3>Any Challenge</h3>
          <ul class="any-list">
            <li>Tax Liens &amp; Delinquency</li>
            <li>Code Violations</li>
            <li>Title Issues</li>
            <li>Behind on Mortgage</li>
            <li>Out of Area Property</li>
            <li>Large Liens</li>
            <li>Estate &amp; Probate</li>
            <li>Zoning Problems</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ COMPARISON ═══ -->
  <section class="section bg-white">
    <div class="container">
      <div class="text-center">
        <span class="eyebrow">The Better Solution</span>
        <h2 class="section-title">Jacob vs. The Traditional Sale</h2>
        <p class="section-sub">Run the real numbers and see why more Wichita homeowners skip the listing process entirely.</p>
      </div>
      <div class="compare-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th></th>
              <th class="th-us">Jacob Buys Your House</th>
              <th class="th-them">Traditional Listing</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Agent Commissions</td><td><span class="check">✓ None — $0</span></td><td><span class="cross">✗ 5–6% of sale price</span></td></tr>
            <tr><td>Closing Costs</td><td><span class="check">✓ We cover them</span></td><td><span class="cross">✗ 1–3% extra</span></td></tr>
            <tr><td>Repairs Required</td><td><span class="check">✓ Zero — sell as-is</span></td><td><span class="cross">✗ Often $10k–$40k+</span></td></tr>
            <tr><td>Time to Close</td><td><span class="check">✓ 7–30 days</span></td><td><span class="cross">✗ 60–120+ days</span></td></tr>
            <tr><td>Showings &amp; Open Houses</td><td><span class="check">✓ None</span></td><td><span class="cross">✗ Weeks of disruption</span></td></tr>
            <tr><td>Financing Fall-Through Risk</td><td><span class="check">✓ Zero — cash buyer</span></td><td><span class="cross">✗ Deals fall apart often</span></td></tr>
            <tr><td>You Choose Closing Date</td><td><span class="check">✓ Always</span></td><td><span class="cross">✗ Buyer dictates terms</span></td></tr>
            <tr><td>Certainty of Sale</td><td><span class="check">✓ Guaranteed</span></td><td><span class="cross">✗ Never guaranteed</span></td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ WHY JACOB (Blue BG) ═══ -->
  <section class="jacob-section">
    <div class="container">
      <div class="grid-2" style="gap:64px">
        <div class="jacob-text-col">
          <span class="eyebrow eyebrow-white">A Different Kind of Buyer</span>
          <h2 class="section-title section-title-white">A Local Buyer You Can Actually Trust</h2>
          <p class="section-sub section-sub-white">I'm not a national hedge fund or an algorithm. I'm Jacob Matlock — I grew up in Derby, I invest in Wichita, and I care about this community.</p>
          <p class="section-sub section-sub-white" style="margin-top:16px">I believe being a good person will produce a greater ROI than any other strategy. No bait-and-switch offers. No last-minute price cuts. Just honest business done right.</p>
          <a href="/about" style="display:inline-flex;align-items:center;gap:8px;color:white;font-weight:700;font-size:15px;text-decoration:none;margin-top:28px;background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.35);padding:12px 24px;border-radius:8px;transition:background .15s">Meet Jacob →</a>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
          <div class="stat-glass"><div class="num">24hr</div><div class="lbl">Cash Offer</div></div>
          <div class="stat-glass"><div class="num">7</div><div class="lbl">Days to Close</div></div>
          <div class="stat-glass"><div class="num">$0</div><div class="lbl">Fees or Commissions</div></div>
          <div class="stat-glass"><div class="num">100%</div><div class="lbl">As-Is Sale</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FORM PLACEHOLDER ═══ -->
  <section class="section bg-blue">
    <div class="container">
      <div class="form-section">
        <div class="form-left">
          <span class="eyebrow" style="color:rgba(255,255,255,.7)">Get Started</span>
          <h2 class="section-title section-title-white">Get Your Fair Cash Offer Today</h2>
          <p class="section-sub section-sub-white">No obligation. No fees. Just a straightforward offer from a local Wichita buyer — within 24 hours.</p>
          <ul class="form-bullets">
            <li>✓ Offer within 24 hours</li>
            <li>✓ Close in as little as 7 days</li>
            <li>✓ We pay all closing costs</li>
            <li>✓ No repairs, no cleaning, no showings</li>
          </ul>
        </div>
        <div class="form-right">
          <div class="form-placeholder">
            <p style="color:#aaa;font-size:14px;text-align:center">📋 Form coming soon</p>
            <p style="color:#888;font-size:13px;text-align:center;margin-top:8px">In the meantime, call or text us:</p>
            <a href="tel:3163683344" style="display:block;text-align:center;font-size:1.4rem;font-weight:800;color:#e87122;margin-top:12px;text-decoration:none">(316) 368-3344</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ AREAS ═══ -->
  <section class="section bg-white">
    <div class="container">
      <div class="text-center" style="margin-bottom:48px">
        <span class="eyebrow">Service Area</span>
        <h2 class="section-title">Cities We Buy Houses In</h2>
        <p class="section-sub">We serve Wichita and all surrounding Sedgwick County communities.</p>
      </div>
