---
import Base from '../layouts/Base.astro';
---
<Base
  title="Sell Your House Fast in Wichita KS | Jacob Buys Your House"
  description="Jacob Matlock buys houses for cash in Wichita KS. Fair offer in 24 hours, close in 7 days. No repairs, no fees, no hassle. Call (316) 816-2983."
>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "RealEstateAgent",
    "name": "Jacob Buys Your House",
    "description": "Local cash home buyer in Wichita, KS.",
    "url": "https://jacobbuysyourhouse.com",
    "telephone": "+13168162983",
    "address": { "@type": "PostalAddress", "addressLocality": "Wichita", "addressRegion": "KS", "addressCountry": "US" },
    "areaServed": ["Wichita","Derby","Mulvane","Haysville","Andover","Augusta","El Dorado"],
    "openingHours": "Mo-Su 08:00-20:00"
  }
  </script>

  <style>
    /* ─── HERO ─── */
    .hero {
      position: relative;
      min-height: 620px;
      display: flex;
      align-items: center;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0;
      background-image: url('/hero-house.jpg');
      background-size: cover;
      background-position: center 40%;
      filter: brightness(.45);
      transform: scale(1.02);
    }
    .hero-content {
      position: relative;
      z-index: 2;
      color: white;
      padding: 80px 0;
      width: 100%;
    }
    .hero-inner { max-width: 720px; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(245,200,66,.15); border: 1px solid rgba(245,200,66,.4);
      color: #f5c842; font-size: 12px; font-weight: 700;
      letter-spacing: 2px; text-transform: uppercase;
      padding: 7px 16px; border-radius: 100px; margin-bottom: 24px;
    }
    .hero h1 {
      font-size: clamp(2.6rem, 5.5vw, 4.2rem);
      font-weight: 900; line-height: 1.1;
      margin-bottom: 20px; letter-spacing: -1.5px;
    }
    .hero h1 span { color: #f5c842; }
    .hero-sub {
      font-size: 18px; opacity: .88; margin-bottom: 40px;
      max-width: 560px; line-height: 1.65;
    }
    .hero-cta { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 48px; }
    .hero-trust {
      display: flex; gap: 12px; flex-wrap: wrap;
    }
    .trust-pill {
      display: inline-flex; align-items: center; gap: 7px;
      background: rgba(255,255,255,.1); backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,.2);
      color: white; font-size: 13px; font-weight: 600;
      padding: 8px 16px; border-radius: 100px;
    }

    /* ─── STATS BAR ─── */
    .stats-bar {
      background: #0f2d1f;
      padding: 28px 0;
      border-top: 3px solid #e07820;
    }
    .stats-inner {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
    }
    .stat-item {
      text-align: center;
      padding: 0 24px;
      border-right: 1px solid rgba(255,255,255,.1);
    }
    .stat-item:last-child { border-right: none; }
    .stat-num { font-size: 2rem; font-weight: 900; color: #f5c842; line-height: 1; margin-bottom: 4px; }
    .stat-label { font-size: 12px; color: rgba(255,255,255,.65); text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }

    /* ─── HOW IT WORKS ─── */
    .step-card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 20px;
      padding: 36px 28px;
      text-align: center;
      box-shadow: 0 2px 20px rgba(0,0,0,.06);
      position: relative;
      transition: all .2s;
    }
    .step-card:hover { transform: translateY(-4px); box-shadow: 0 8px 40px rgba(0,0,0,.1); }
    .step-num {
      width: 60px; height: 60px;
      background: linear-gradient(135deg, #1a4731, #0f2d1f);
      color: white; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.6rem; font-weight: 900;
      margin: 0 auto 20px;
      box-shadow: 0 4px 16px rgba(15,45,31,.35);
    }
    .step-card h3 { font-size: 1.05rem; font-weight: 700; color: #1e293b; margin-bottom: 10px; }
    .step-card p { font-size: 14.5px; color: #64748b; line-height: 1.65; }

    /* ─── ANY SECTION ─── */
    .any-card {
      background: white;
      border-radius: 20px;
      padding: 36px 30px;
      box-shadow: 0 2px 20px rgba(0,0,0,.06);
      border: 1px solid #e2e8f0;
    }
    .any-icon { font-size: 2rem; margin-bottom: 16px; }
    .any-card h3 { font-size: 1.1rem; font-weight: 800; color: #1a4731; margin-bottom: 18px; }
    .any-list { list-style: none; }
    .any-list li {
      padding: 9px 0 9px 24px; position: relative;
      font-size: 14.5px; color: #475569;
      border-bottom: 1px solid #f1f5f9;
    }
    .any-list li:last-child { border: none; padding-bottom: 0; }
    .any-list li::before { content: "✓"; position: absolute; left: 0; color: #1a4731; font-weight: 800; }

    /* ─── COMPARISON ─── */
    .compare-wrap { overflow-x: auto; margin-top: 48px; }
    .compare-table { width: 100%; border-collapse: separate; border-spacing: 0; border-radius: 16px; overflow: hidden; box-shadow: 0 2px 24px rgba(0,0,0,.08); }
    .compare-table th { padding: 20px 24px; font-size: 14px; font-weight: 700; text-align: center; }
    .compare-table th:first-child { text-align: left; background: #f8fafc; color: #64748b; width: 35%; }
    .th-us { background: #1a4731; color: white; }
    .th-them { background: #f1f5f9; color: #94a3b8; }
    .compare-table td { padding: 16px 24px; font-size: 14.5px; text-align: center; }
    .compare-table td:first-child { text-align: left; font-weight: 600; color: #334155; background: #fafafa; }
    .compare-table tr:nth-child(even) td { background: #f8fafc; }
    .compare-table tr:nth-child(even) td:first-child { background: #f1f5f9; }
    .check { color: #16a34a; font-weight: 700; }
    .cross { color: #dc2626; font-weight: 700; }

    /* ─── TESTIMONIAL ─── */
    .testimonial {
      background: white;
      border-radius: 20px;
      padding: 36px;
      box-shadow: 0 2px 20px rgba(0,0,0,.06);
      border: 1px solid #e2e8f0;
      border-top: 4px solid #e07820;
    }
    .stars { color: #f59e0b; font-size: 18px; margin-bottom: 16px; }
    .testimonial-text { font-size: 16px; color: #475569; line-height: 1.7; font-style: italic; margin-bottom: 20px; }
    .testimonial-author { font-weight: 700; color: #1e293b; font-size: 14px; }

    /* ─── AREAS ─── */
    .area-chip {
      background: white;
      border: 1.5px solid #e2e8f0;
      color: #1a4731; font-weight: 700;
      font-size: 13.5px; padding: 12px 16px;
      border-radius: 10px; text-decoration: none;
      text-align: center; display: block;
      transition: all .15s;
    }
    .area-chip:hover { background: #1a4731; color: white; border-color: #1a4731; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(26,71,49,.2); }

    /* ─── FAQ ─── */
    .faq-item {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      padding: 24px 28px;
      transition: box-shadow .15s;
    }
    .faq-item:hover { box-shadow: 0 4px 20px rgba(0,0,0,.07); }
    .faq-item h3 { font-size: 15px; font-weight: 700; color: #1a4731; margin-bottom: 10px; }
    .faq-item p { font-size: 14.5px; color: #475569; margin: 0; line-height: 1.65; }

    /* ─── CTA SECTION ─── */
    .cta-section {
      background: linear-gradient(135deg, #1a4731 0%, #0f2d1f 100%);
      padding: 88px 0;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta-section::before {
      content: '';
      position: absolute; inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .cta-section h2 { font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 900; color: white; margin-bottom: 16px; position: relative; }
    .cta-section p { font-size: 18px; color: rgba(255,255,255,.8); margin-bottom: 40px; position: relative; }
    .cta-section .btn-primary { position: relative; font-size: 17px; padding: 18px 48px; }

    @media(max-width: 640px) {
      .stats-inner { grid-template-columns: repeat(2,1fr); }
      .stat-item:nth-child(2) { border-right: none; }
      .stat-item:nth-child(3) { border-top: 1px solid rgba(255,255,255,.1); }
      .hero-trust { gap: 8px; }
    }
  </style>

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-content">
      <div class="hero-inner">
        <div class="hero-badge">✦ Wichita's Local Cash Home Buyer</div>
        <h1>Sell Your House<br/><span>Fast in Wichita.</span></h1>
        <p class="hero-sub">Jacob Matlock pays cash for homes in any condition. Fair offer within 24 hours. Close in as little as 7 days — on your schedule.</p>
        <div class="hero-cta">
          <a href="tel:3168162983" class="btn-primary">📞 Call (316) 816-2983</a>
          <a href="/contact" class="btn-secondary">Get a Cash Offer →</a>
        </div>
        <div class="hero-trust">
          <div class="trust-pill">⭐⭐⭐⭐⭐ 5-Star Rated</div>
          <div class="trust-pill">✅ No Fees or Commissions</div>
          <div class="trust-pill">⚡ Offer in 24 Hours</div>
          <div class="trust-pill">🏠 Close in 7 Days</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ STATS BAR ═══ -->
  <div class="stats-bar">
    <div class="container">
      <div class="stats-inner">
        <div class="stat-item"><div class="stat-num">24hr</div><div class="stat-label">Cash Offer</div></div>
        <div class="stat-item"><div class="stat-num">7 Days</div><div class="stat-label">To Close</div></div>
        <div class="stat-item"><div class="stat-num">$0</div><div class="stat-label">Fees & Commissions</div></div>
        <div class="stat-item"><div class="stat-num">100%</div><div class="stat-label">As-Is — No Repairs</div></div>
      </div>
    </div>
  </div>

  <!-- ═══ HOW IT WORKS ═══ -->
  <section class="section bg-light">
    <div class="container">
      <div class="text-center" style="margin-bottom:48px">
        <span class="eyebrow">Simple Process</span>
        <h2 class="section-title">How It Works</h2>
        <p class="section-sub">Three steps. No surprises. We handle everything so you can focus on what's next.</p>
      </div>
      <div class="grid-3">
        <div class="step-card">
          <div class="step-num">1</div>
          <h3>Tell Us About Your Home</h3>
          <p>Call, text, or fill out a short form. Share basic info about your property — takes less than 5 minutes. Zero obligation.</p>
        </div>
        <div class="step-card">
          <div class="step-num">2</div>
          <h3>Receive a Fair Cash Offer</h3>
          <p>We assess your property and present a real cash offer within 24 hours — based on actual Wichita market data, not guesswork.</p>
        </div>
        <div class="step-card">
          <div class="step-num">3</div>
          <h3>Pick Your Closing Date</h3>
          <p>Accept the offer and choose a date that works for you — as fast as 7 days or as far out as you need. We take care of the paperwork.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ANY REASON / CONDITION / CHALLENGE ═══ -->
  <section class="section bg-white">
    <div class="container">
      <div class="text-center" style="margin-bottom:48px">
        <span class="eyebrow">We Handle It All</span>
        <h2 class="section-title">We Buy Houses in Any Situation</h2>
        <p class="section-sub">There's no situation we haven't seen. Whatever brought you here — there's a path forward.</p>
      </div>
      <div class="grid-3">
        <div class="any-card">
          <div class="any-icon">🏡</div>
          <h3>Any Reason</h3>
          <ul class="any-list">
            <li>Inherited Property</li>
            <li>Facing Foreclosure</li>
            <li>Going Through Divorce</li>
            <li>Tired Landlord</li>
            <li>Relocating for Work</li>
            <li>Downsizing</li>
            <li>Bankruptcy</li>
            <li>Health Issues</li>
          </ul>
        </div>
        <div class="any-card">
          <div class="any-icon">🔨</div>
          <h3>Any Condition</h3>
          <ul class="any-list">
            <li>Major Repairs Needed</li>
            <li>Fire or Storm Damage</li>
            <li>Full of Stuff or Trash</li>
            <li>Problem Tenants</li>
            <li>Foundation Issues</li>
            <li>Old & Outdated</li>
            <li>Hoarder Home</li>
            <li>Unfinished Construction</li>
          </ul>
        </div>
        <div class="any-card">
          <div class="any-icon">⚡</div>
          <h3>Any Challenge</h3>
          <ul class="any-list">
            <li>Tax Liens & Delinquency</li>
            <li>Code Violations</li>
            <li>Title Issues</li>
            <li>Behind on Mortgage</li>
            <li>Out of Area Property</li>
            <li>Large Liens</li>
            <li>Zoning Issues</li>
            <li>Family & Estate Matters</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ WHY JACOB ═══ -->
  <section class="section" style="background: linear-gradient(135deg, #1a4731 0%, #0f2d1f 100%)">
    <div class="container">
      <div class="grid-2" style="gap:60px">
        <div>
          <span class="eyebrow eyebrow-light">A Different Kind of Buyer</span>
          <h2 class="section-title section-title-white">A Local Buyer You Can Actually Trust</h2>
          <p class="section-sub section-sub-white">I'm not a national hedge fund or an algorithm. I'm Jacob Matlock — I grew up in the Derby/Wichita area, I invest here, and I care about this community.</p>
          <p class="section-sub section-sub-white" style="margin-top:16px">I started buying houses because I believe being a good person will produce a greater ROI than any other strategy. No bait-and-switch offers. No last-minute price cuts. Just honest business.</p>
          <a href="/about" style="display:inline-flex;align-items:center;gap:8px;color:#f5c842;font-weight:700;font-size:15px;text-decoration:none;margin-top:28px;">Meet Jacob →</a>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
          <div style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:16px;padding:28px;text-align:center">
            <div style="font-size:2.4rem;font-weight:900;color:#f5c842">24hr</div>
            <div style="font-size:13px;color:rgba(255,255,255,.7);text-transform:uppercase;letter-spacing:1px;margin-top:4px">Cash Offer</div>
          </div>
          <div style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:16px;padding:28px;text-align:center">
            <div style="font-size:2.4rem;font-weight:900;color:#f5c842">7</div>
            <div style="font-size:13px;color:rgba(255,255,255,.7);text-transform:uppercase;letter-spacing:1px;margin-top:4px">Days to Close</div>
          </div>
          <div style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:16px;padding:28px;text-align:center">
            <div style="font-size:2.4rem;font-weight:900;color:#f5c842">$0</div>
            <div style="font-size:13px;color:rgba(255,255,255,.7);text-transform:uppercase;letter-spacing:1px;margin-top:4px">Fees or Commissions</div>
          </div>
          <div style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:16px;padding:28px;text-align:center">
            <div style="font-size:2.4rem;font-weight:900;color:#f5c842">100%</div>
            <div style="font-size:13px;color:rgba(255,255,255,.7);text-transform:uppercase;letter-spacing:1px;margin-top:4px">As-Is Sale</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ COMPARISON ═══ -->
  <section class="section bg-light">
    <div class="container">
      <div class="text-center" style="margin-bottom:0">
        <span class="eyebrow">The Better Solution</span>
        <h2 class="section-title">Jacob vs. The Traditional Sale</h2>
        <p class="section-sub">Run the real numbers and see why more Wichita homeowners skip the listing process entirely.</p>
      </div>
      <div class="compare-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th></th>
              <th class="th-us">Jacob Buys Your House</th>
              <th class="th-them">Traditional Listing</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Agent Commissions</td><td><span class="check">✓ None — $0</span></td><td><span class="cross">✗ 5–6% of sale price</span></td></tr>
            <tr><td>Closing Costs</td><td><span class="check">✓ We cover them</span></td><td><span class="cross">✗ 1–3% extra</span></td></tr>
            <tr><td>Repairs Required</td><td><span class="check">✓ Zero — sell as-is</span></td><td><span class="cross">✗ Often $10k–$40k+</span></td></tr>
            <tr><td>Time to Close</td><td><span class="check">✓ 7–30 days</span></td><td><span class="cross">✗ 60–120+ days</span></td></tr>
            <tr><td>Showings & Open Houses</td><td><span class="check">✓ None</span></td><td><span class="cross">✗ Weeks of disruption</span></td></tr>
            <tr><td>Financing Fall-Through Risk</td><td><span class="check">✓ Zero — cash buyer</span></td><td><span class="cross">✗ 10–15% of deals fall</span></td></tr>
            <tr><td>You Choose Closing Date</td><td><span class="check">✓ Always</span></td><td><span class="cross">✗ Buyer dictates terms</span></td></tr>
            <tr><td>Certainty of Sale</td><td><span class="check">✓ Guaranteed</span></td><td><span class="cross">✗ Never guaranteed</span></td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ AREAS ═══ -->
  <section class="section bg-white">
    <div class="container">
      <div class="text-center" style="margin-bottom:40px">
        <span class="eyebrow">Service Area</span>
        <h2 class="section-title">Cities We Buy Houses In</h2>
        <p class="section-sub">Wichita and all surrounding Sedgwick County communities.</p>
      </div>
      <div class="grid-areas">
        <a href="/areas/wichita" class="area-chip">Wichita</a>
        <a href="/areas/derby" class="area-chip">Derby</a>
        <a href="/areas/mulvane" class="area-chip">Mulvane</a>
        <a href="/areas/haysville" class="area-chip">Haysville</a>
        <a href="/areas/andover" class="area-chip">Andover</a>
        <a href="/areas/augusta" class="area-chip">Augusta</a>
        <a href="/areas/el-dorado" class="area-chip">El Dorado</a>
        <a href="/areas/park-city" class="area-chip">Park City</a>
        <a href="/areas/bel-aire" class="area-chip">Bel Aire</a>
        <a href="/areas/valley-center" class="area-chip">Valley Center</a>
        <a href="/areas/goddard" class="area-chip">Goddard</a>
        <a href="/areas/maize" class="area-chip">Maize</a>
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="section bg-light">
    <div class="container">
      <div class="text-center" style="margin-bottom:48px">
        <span class="eyebrow">Common Questions</span>
        <h2 class="section-title">Frequently Asked Questions</h2>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;max-width:900px;margin:0 auto">
        <div class="faq-item"><h3>How fast can you close?</h3><p>As fast as 7 days. We use a local Wichita title company and handle all paperwork. You pick the date.</p></div>
        <div class="faq-item"><h3>Do I need to make repairs or clean?</h3><p>No. We buy as-is. Leave whatever you don't want — furniture, trash, belongings. We handle it all.</p></div>
        <div class="faq-item"><h3>Is the cash offer actually fair?</h3><p>We base offers on real Wichita market data. We won't insult you with a low number. If it doesn't work, no hard feelings.</p></div>
        <div class="faq-item"><h3>Are there any fees or commissions?</h3><p>None. What we offer is what you receive — no deductions, no surprises at the closing table.</p></div>
        <div class="faq-item"><h3>My house is in really bad shape. Will you buy it?</h3><p>Yes. Foundation problems, fire damage, hoarder situations — condition doesn't scare us at all.</p></div>
        <div class="faq-item"><h3>I'm not sure I want to sell yet. Should I call?</h3><p>Absolutely. No pressure, no obligation. Jacob will walk through your options honestly and let you decide.</p></div>
      </div>
    </div>
  </section>

  <!-- ═══ FINAL CTA ═══ -->
  <section class="cta-section">
    <div class="container">
      <h2>Ready to Get Your Cash Offer?</h2>
      <p>No obligation. No pressure. Just a straight answer from a local Wichita buyer who answers his own phone.</p>
      <a href="tel:3168162983" class="btn-primary">📞 Call (316) 816-2983</a>
    </div>
  </section>

</Base>
