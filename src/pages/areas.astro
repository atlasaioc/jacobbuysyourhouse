---
import Base from '../layouts/Base.astro';
---
<Base
  title="Areas We Buy Houses | Wichita KS and Surrounding Cities"
  description="Jacob buys houses throughout Wichita and surrounding Sedgwick County cities including Derby, Mulvane, Haysville, Andover, Augusta, and El Dorado."
>
  <section class="hero">
    <div class="container">
      <h1>Areas We Serve</h1>
      <p>We buy houses throughout Wichita and all surrounding communities in Sedgwick County and beyond.</p>
      <a href="tel:3163683344" class="btn-primary">Call (316) 368-3344</a>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <h2>Cities We Buy Houses In</h2>
      <div class="areas-grid">
        <a href="/areas/wichita" class="area-card">Wichita</a>
        <a href="/areas/derby" class="area-card">Derby</a>
        <a href="/areas/mulvane" class="area-card">Mulvane</a>
        <a href="/areas/haysville" class="area-card">Haysville</a>
        <a href="/areas/andover" class="area-card">Andover</a>
        <a href="/areas/augusta" class="area-card">Augusta</a>
        <a href="/areas/el-dorado" class="area-card">El Dorado</a>
        <a href="/areas/park-city" class="area-card">Park City</a>
        <a href="/areas/bel-aire" class="area-card">Bel Aire</a>
        <a href="/areas/valley-center" class="area-card">Valley Center</a>
        <a href="/areas/goddard" class="area-card">Goddard</a>
        <a href="/areas/maize" class="area-card">Maize</a>
      </div>
      <div class="content-page">
        <h2>Not Seeing Your City?</h2>
        <p>We serve all of Sedgwick County and the surrounding area. If your property is within about 30 miles of Wichita, there's a good chance we buy there. Call us and find out.</p>
        <p><a href="tel:3163683344"><strong>(316) 368-3344</strong></a></p>
      </div>
    </div>
  </section>
</Base>
