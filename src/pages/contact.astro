---
import InnerPage from '../layouts/InnerPage.astro';
import LeadForm from '../components/LeadForm.astro';
---
<InnerPage
  title="Get a Cash Offer | Contact Jacob | Wichita KS"
  description="Submit your property address and get a fair cash offer within 24 hours. No fees, no pressure. Call or text (316) 368-3344."
  heroImage="/situations/contact.jpg"
  heroTitle="Get Your Cash Offer"
  heroSub="Fill out the form or call directly. Jacob will get back to you within a few hours. No pressure, no obligation."
>

  <style>
    .contact-split { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 32px; }
    .contact-info-card { background: #f3f5f8; border-radius: 14px; padding: 24px; border: 1px solid #e0e8f0; }
    .contact-info-card .c-icon { font-size: 1.8rem; margin-bottom: 10px; }
    .contact-info-card h3 { font-size: 14px; font-weight: 700; color: #1a82d8; margin-bottom: 5px; }
    .contact-info-card p { font-size: 14px; color: #555; margin: 0; line-height: 1.55; }
    .contact-info-card a { color: #e87122; font-weight: 700; text-decoration: none; font-size: 1.05rem; }
    @media(max-width:600px){ .contact-split { grid-template-columns: 1fr; } }
  </style>

  <h2>Submit Your Property</h2>
  <LeadForm />

  <h2 style="margin-top:48px">Or Reach Jacob Directly</h2>
  <div class="contact-split">
    <div class="contact-info-card">
      <div class="c-icon">📞</div>
      <h3>Call or Text</h3>
      <p>Jacob answers his own phone. Best way to reach us fast.</p>
      <a href="tel:3163683344">(316) 368-3344</a>
    </div>
    <div class="contact-info-card">
      <div class="c-icon">⚡</div>
      <h3>Response Time</h3>
      <p>Cash offer delivered within 24 hours. Most calls returned same day.</p>
    </div>
    <div class="contact-info-card">
      <div class="c-icon">🗓</div>
      <h3>Availability</h3>
      <p>7 days a week, 8am–8pm. Reach out whenever it's convenient.</p>
    </div>
    <div class="contact-info-card">
      <div class="c-icon">📍</div>
      <h3>Service Area</h3>
      <p>Wichita, Derby, Mulvane, Haysville, Andover, Augusta, El Dorado, and surrounding Sedgwick County communities.</p>
    </div>
  </div>

  <h2>What Happens After You Submit</h2>
  <div class="steps-list">
    <div class="step-row">
      <div class="step-circle">1</div>
      <div class="step-body">
        <h3>Jacob Reviews Your Property</h3>
        <p>We look at the address, condition notes, and your situation to build an initial assessment.</p>
      </div>
    </div>
    <div class="step-row">
      <div class="step-circle">2</div>
      <div class="step-body">
        <h3>We Reach Out Within Hours</h3>
        <p>Jacob calls or texts you directly — usually same day — to ask a few questions and discuss next steps.</p>
      </div>
    </div>
    <div class="step-row">
      <div class="step-circle">3</div>
      <div class="step-body">
        <h3>You Get a Real Offer in 24 Hours</h3>
        <p>Based on actual Wichita market data. We walk you through the number and you decide — no pressure.</p>
      </div>
    </div>
  </div>

</InnerPage>
