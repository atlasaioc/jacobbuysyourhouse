---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
}
const { title, description, canonical } = Astro.props;
const url = canonical || Astro.url.href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={url} />
  <meta name="robots" content="index, follow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: #1a1a1a; line-height: 1.6; }
    a { color: #e07820; }
    img { max-width: 100%; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }

    /* TOP BAR */
    .top-bar { background: #1a1a1a; color: white; text-align: center; padding: 8px 20px; font-size: .9rem; display: flex; justify-content: space-between; align-items: center; }
    .top-bar a { color: #f0c040; font-weight: 700; text-decoration: none; }

    /* HEADER */
    header { background: white; padding: 16px 0; border-bottom: 2px solid #f0f0f0; position: sticky; top: 0; z-index: 100; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
    .header-inner { display: flex; justify-content: space-between; align-items: center; }
    .logo { font-size: 1.5rem; font-weight: 900; color: #1a1a1a; text-decoration: none; letter-spacing: -1px; }
    .logo span { color: #e07820; }
    nav a { color: #333; text-decoration: none; margin-left: 24px; font-size: .95rem; font-weight: 500; }
    nav a:hover { color: #e07820; }
    .btn-offer { background: #e07820; color: white !important; font-weight: 700; padding: 12px 24px; border-radius: 5px; margin-left: 24px; }
    .btn-offer:hover { background: #c96a10 !important; }

    /* HERO — full width house photo */
    .hero { position: relative; min-height: 560px; display: flex; align-items: center; background: linear-gradient(rgba(10,20,10,0.65), rgba(10,20,10,0.65)), url('https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=1600&q=80') center/cover no-repeat; color: white; text-align: center; padding: 80px 20px; }
    .hero-eyebrow { color: #f0c040; font-size: 1rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 16px; }
    .hero h1 { font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 900; line-height: 1.15; margin-bottom: 16px; }
    .hero-sub { font-size: 1.2rem; opacity: .9; margin-bottom: 36px; }
    .hero-cta { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .btn-primary { display: inline-block; background: #e07820; color: white; font-weight: 800; font-size: 1.1rem; padding: 18px 42px; border-radius: 5px; text-decoration: none; transition: background .15s; }
    .btn-primary:hover { background: #c96a10; color: white; }
    .btn-ghost { display: inline-block; background: transparent; border: 2px solid white; color: white; font-weight: 700; font-size: 1rem; padding: 16px 36px; border-radius: 5px; text-decoration: none; }
    .hero-trust { margin-top: 40px; display: flex; gap: 32px; justify-content: center; align-items: center; flex-wrap: wrap; }
    .trust-badge { background: rgba(255,255,255,.15); border: 1px solid rgba(255,255,255,.3); border-radius: 8px; padding: 12px 20px; font-size: .9rem; font-weight: 600; }

    /* PROOF BAR */
    .proof-bar { background: #1a3a2a; color: white; padding: 20px 0; }
    .proof-inner { display: flex; justify-content: center; gap: 48px; flex-wrap: wrap; text-align: center; }
    .proof-item .num { font-size: 1.8rem; font-weight: 900; color: #f0c040; }
    .proof-item .label { font-size: .85rem; opacity: .8; }

    /* SECTIONS */
    .section { padding: 72px 0; }
    .section-alt { background: #f7f7f5; }
    .section-dark { background: #1a3a2a; color: white; }
    .section h2 { font-size: clamp(1.7rem, 3vw, 2.2rem); margin-bottom: 16px; }
    .section-dark h2 { color: white; }
    .section p { font-size: 1.05rem; color: #444; margin-bottom: 16px; max-width: 680px; }
    .section-dark p { color: rgba(255,255,255,.85); }
    .eyebrow { font-size: .85rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #e07820; margin-bottom: 8px; }
    .section-dark .eyebrow { color: #f0c040; }
    .text-center { text-align: center; }
    .text-center p { margin: 0 auto 16px; }

    /* STEPS */
    .steps-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 28px; margin-top: 40px; }
    .step { background: white; border-radius: 10px; padding: 32px 24px; box-shadow: 0 2px 16px rgba(0,0,0,.07); text-align: center; }
    .step-num { width: 54px; height: 54px; background: #e07820; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: 900; margin: 0 auto 16px; }
    .step h3 { font-size: 1.1rem; margin-bottom: 8px; }
    .step p { font-size: .95rem; color: #666; }

    /* ANY REASON/CONDITION/CHALLENGE */
    .any-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 40px; }
    @media(max-width:700px){ .any-grid { grid-template-columns: 1fr; } }
    .any-card { background: white; border-radius: 10px; padding: 32px 28px; box-shadow: 0 2px 16px rgba(0,0,0,.07); }
    .any-card h3 { font-size: 1.15rem; color: #e07820; margin-bottom: 16px; font-weight: 800; }
    .any-card ul { list-style: none; }
    .any-card li { padding: 6px 0; border-bottom: 1px solid #f0f0f0; font-size: .95rem; color: #444; }
    .any-card li:last-child { border: none; }
    .any-card li::before { content: "✓ "; color: #1a3a2a; font-weight: 700; }

    /* COMPARISON */
    .compare-table { width: 100%; border-collapse: collapse; margin-top: 40px; }
    .compare-table th { padding: 16px; text-align: center; font-size: 1rem; }
    .compare-table th:first-child { text-align: left; }
    .compare-table th.us { background: #1a3a2a; color: white; border-radius: 8px 8px 0 0; }
    .compare-table th.them { background: #e0e0e0; color: #555; border-radius: 8px 8px 0 0; }
    .compare-table td { padding: 14px 16px; border-bottom: 1px solid #eee; font-size: .95rem; text-align: center; }
    .compare-table td:first-child { text-align: left; font-weight: 600; color: #333; }
    .compare-table tr:nth-child(even) td { background: #f9f9f9; }
    .check { color: #1a9a4a; font-size: 1.2rem; }
    .cross { color: #cc3333; font-size: 1.2rem; }

    /* SITUATIONS */
    .situations-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-top: 32px; }
    .situation-card { background: white; border: 1px solid #e8e8e8; border-radius: 8px; padding: 24px; transition: box-shadow .15s; }
    .situation-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,.1); }
    .situation-card h3 { color: #1a3a2a; font-size: 1.05rem; margin-bottom: 8px; }
    .situation-card p { font-size: .9rem; color: #666; margin: 0; }
    .situation-card a { display: inline-block; margin-top: 12px; font-weight: 600; font-size: .9rem; color: #e07820; text-decoration: none; }

    /* AREAS */
    .areas-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; margin-top: 32px; }
    .area-card { background: #1a3a2a; color: white; border-radius: 6px; padding: 16px; text-align: center; text-decoration: none; font-weight: 600; font-size: .95rem; transition: background .15s; }
    .area-card:hover { background: #e07820; color: white; }

    /* FAQ */
    .faq-grid { margin-top: 40px; display: grid; gap: 16px; }
    .faq-item { border: 1px solid #e8e8e8; border-radius: 8px; padding: 24px; background: white; }
    .faq-item h3 { font-size: 1rem; font-weight: 700; margin-bottom: 10px; color: #1a3a2a; }
    .faq-item p { font-size: .95rem; color: #555; margin: 0; }

    /* CTA */
    .cta-block { background: #e07820; padding: 64px 0; text-align: center; }
    .cta-block h2 { font-size: 2rem; color: white; margin-bottom: 12px; }
    .cta-block p { font-size: 1.1rem; color: rgba(255,255,255,.9); margin-bottom: 28px; max-width: 600px; margin-left: auto; margin-right: auto; }
    .btn-dark { display: inline-block; background: #1a3a2a; color: white; font-weight: 800; font-size: 1.1rem; padding: 18px 42px; border-radius: 5px; text-decoration: none; }
    .btn-dark:hover { background: #0d2418; color: white; }

    /* FOOTER */
    footer { background: #111; color: #aaa; padding: 48px 0 24px; }
    .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 36px; margin-bottom: 36px; }
    footer h4 { color: white; margin-bottom: 14px; font-size: 1rem; }
    footer a { color: #aaa; text-decoration: none; display: block; margin-bottom: 7px; font-size: .9rem; }
    footer a:hover { color: #e07820; }
    .footer-bottom { text-align: center; padding-top: 24px; border-top: 1px solid #333; font-size: .85rem; }

    /* CONTENT PAGE */
    .content-page { padding: 60px 0; max-width: 820px; margin: 0 auto; }
    .content-page h1 { font-size: 2.2rem; color: #1a3a2a; margin-bottom: 24px; line-height: 1.3; }
    .content-page h2 { font-size: 1.5rem; color: #1a3a2a; margin: 40px 0 16px; }
    .content-page p { margin-bottom: 18px; font-size: 1.05rem; line-height: 1.75; color: #333; }
    .content-page ul { margin: 0 0 18px 24px; }
    .content-page li { margin-bottom: 8px; font-size: 1.05rem; color: #333; }

    /* RESPONSIVE */
    @media(max-width:768px){
      nav { display: none; }
      .top-bar { font-size: .8rem; }
      .proof-inner { gap: 24px; }
    }
  </style>
</head>
<body>
  <!-- TOP BAR -->
  <div class="top-bar">
    <span>Your Local Wichita Cash Home Buyer</span>
    <a href="tel:3168162983">Call or Text (316) 816-2983</a>
  </div>

  <!-- HEADER -->
  <header>
    <div class="container header-inner">
      <a href="/" class="logo">Jacob<span>Buys</span>YourHouse<span>.com</span></a>
      <nav>
        <a href="/about">About Jacob</a>
        <a href="/how-it-works">How It Works</a>
        <a href="/areas">Areas</a>
        <a href="/blog">Blog</a>
        <a href="/contact">Contact</a>
      </nav>
      <a href="/contact" class="btn-offer">Get Your Offer</a>
    </div>
  </header>

  <slot />

  <!-- FOOTER -->
  <footer>
    <div class="container">
      <div class="footer-grid">
        <div>
          <h4>Jacob Buys Your House</h4>
          <p style="font-size:.9rem;margin-bottom:14px;line-height:1.6;">Local cash home buyer in Wichita, KS. We buy houses fast, as-is, for a fair price. No fees. No repairs. No hassle.</p>
          <a href="tel:3168162983" style="color:#e07820;font-weight:700;font-size:1rem;">(316) 816-2983</a>
        </div>
        <div>
          <h4>Situations We Help</h4>
          <a href="/sell/inherited-house">Inherited Property</a>
          <a href="/sell/foreclosure">Stopping Foreclosure</a>
          <a href="/sell/divorce">Going Through Divorce</a>
          <a href="/sell/as-is">Selling As-Is</a>
          <a href="/sell/rental-property">Tired Landlords</a>
          <a href="/sell/behind-on-taxes">Behind on Taxes</a>
          <a href="/sell/probate">Probate Sale</a>
        </div>
        <div>
          <h4>Areas We Serve</h4>
          <a href="/areas/wichita">Wichita, KS</a>
          <a href="/areas/derby">Derby, KS</a>
          <a href="/areas/mulvane">Mulvane, KS</a>
          <a href="/areas/haysville">Haysville, KS</a>
          <a href="/areas/andover">Andover, KS</a>
          <a href="/areas/augusta">Augusta, KS</a>
          <a href="/areas/el-dorado">El Dorado, KS</a>
        </div>
        <div>
          <h4>Quick Links</h4>
          <a href="/how-it-works">How It Works</a>
          <a href="/about">About Jacob</a>
          <a href="/faq">FAQ</a>
          <a href="/blog">Blog</a>
          <a href="/contact">Contact Us</a>
        </div>
      </div>
      <div class="footer-bottom">
        &copy; {new Date().getFullYear()} Jacob Buys Your House &middot; Wichita, KS &middot; <a href="/privacy">Privacy Policy</a>
      </div>
    </div>
  </footer>
</body>
</html>
