---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
}
const { title, description, canonical } = Astro.props;
const url = canonical || Astro.url.href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="robots" content="index, follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #3aa1f8;
      --blue-dark: #1a82d8;
      --blue-deeper: #0d5fa0;
      --blue-light: #e8f5ff;
      --blue-mid: #cce8ff;
      --orange: #e87122;
      --orange-dark: #c45a12;
      --orange-light: #fff3eb;
      --white: #ffffff;
      --text: #1d1d1d;
      --text-light: #555;
      --gray: #888;
      --gray-light: #f3f5f8;
      --border: #e0e8f0;
      --shadow: 0 2px 12px rgba(58,161,248,.1), 0 1px 4px rgba(0,0,0,.06);
      --shadow-lg: 0 8px 40px rgba(58,161,248,.15), 0 2px 8px rgba(0,0,0,.06);
    }

    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); line-height: 1.6; background: white; -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }

    .container { max-width: 1140px; margin: 0 auto; padding: 0 24px; }

    /* ─── TOP BAR ─── */
    .topbar { background: #1d1d1d; color: rgba(255,255,255,.8); font-size: 13px; font-weight: 500; padding: 9px 0; }
    .topbar-inner { display: flex; justify-content: space-between; align-items: center; }
    .topbar a { color: var(--blue); font-weight: 700; text-decoration: none; font-size: 14px; }
    .topbar a:hover { color: white; }

    /* ─── HEADER ─── */
    .site-header { background: white; position: sticky; top: 0; z-index: 200; border-bottom: 1px solid var(--border); box-shadow: 0 2px 12px rgba(0,0,0,.06); }
    .header-inner { display: flex; justify-content: space-between; align-items: center; height: 72px; }
    .logo { font-size: 24px; font-weight: 900; color: #1d1d1d; text-decoration: none; letter-spacing: -0.5px; line-height: 1; }
    .logo-buys { color: #3aa1f8; }
    .logo-com { color: #999; font-weight: 500; font-size: 14px; }
    .site-nav { display: flex; align-items: center; gap: 4px; }
    .site-nav a { color: var(--text-light); text-decoration: none; font-size: 14px; font-weight: 500; padding: 8px 12px; border-radius: 6px; transition: all .15s; white-space: nowrap; }
    .site-nav a:hover { color: var(--blue); background: var(--blue-light); }
    .btn-nav { background: var(--orange) !important; color: white !important; font-weight: 700 !important; padding: 10px 22px !important; border-radius: 7px; font-size: 14px; white-space: nowrap; }
    .btn-nav:hover { background: var(--orange-dark) !important; }

    /* ─── BUTTONS ─── */
    .btn-primary { display: inline-flex; align-items: center; gap: 8px; background: var(--orange); color: white; font-weight: 700; font-size: 16px; padding: 16px 36px; border-radius: 8px; text-decoration: none; transition: all .2s; box-shadow: 0 4px 16px rgba(232,113,34,.4); white-space: nowrap; }
    .btn-primary:hover { background: var(--orange-dark); color: white; transform: translateY(-1px); box-shadow: 0 6px 22px rgba(232,113,34,.5); }

    .btn-secondary { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,.15); color: white; font-weight: 600; font-size: 15px; padding: 15px 32px; border-radius: 8px; text-decoration: none; border: 1.5px solid rgba(255,255,255,.45); transition: all .2s; white-space: nowrap; backdrop-filter: blur(4px); }
    .btn-secondary:hover { background: rgba(255,255,255,.25); color: white; }

    .btn-dark { display: inline-flex; align-items: center; gap: 8px; background: #1d1d1d; color: white; font-weight: 700; font-size: 16px; padding: 16px 40px; border-radius: 8px; text-decoration: none; transition: all .2s; }
    .btn-dark:hover { background: #000; color: white; transform: translateY(-1px); }

    .btn-blue { display: inline-flex; align-items: center; gap: 8px; background: var(--blue); color: white; font-weight: 700; font-size: 16px; padding: 16px 40px; border-radius: 8px; text-decoration: none; box-shadow: 0 4px 16px rgba(58,161,248,.4); transition: all .2s; }
    .btn-blue:hover { background: var(--blue-dark); color: white; transform: translateY(-1px); }

    /* ─── SECTIONS ─── */
    .section { padding: 88px 0; }
    .section-sm { padding: 56px 0; }
    .bg-light { background: var(--gray-light); }
    .bg-blue { background: var(--blue); }
    .bg-dark { background: #1d1d1d; }
    .bg-white { background: white; }
    .bg-blue-light { background: var(--blue-light); }

    .eyebrow { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase; color: var(--orange); margin-bottom: 12px; }
    .eyebrow-white { color: rgba(255,255,255,.75); }
    .eyebrow-blue { color: var(--blue); }

    .section-title { font-size: clamp(1.75rem, 3.5vw, 2.4rem); font-weight: 800; color: var(--text); line-height: 1.2; margin-bottom: 16px; letter-spacing: -0.5px; }
    .section-title-white { color: white; }
    .section-sub { font-size: 17px; color: var(--text-light); max-width: 620px; line-height: 1.7; }
    .section-sub-white { color: rgba(255,255,255,.85); }
    .text-center { text-align: center; }
    .text-center .section-sub { margin: 0 auto; }

    /* ─── CARDS ─── */
    .card { background: white; border: 1px solid var(--border); border-radius: 16px; padding: 32px; box-shadow: var(--shadow); transition: all .2s; }
    .card:hover { box-shadow: var(--shadow-lg); transform: translateY(-2px); }

    /* ─── GRIDS ─── */
    .grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; }
    .grid-4 { display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; }
    .grid-2 { display: grid; grid-template-columns: repeat(2,1fr); gap: 40px; align-items: center; }
    .grid-areas { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px,1fr)); gap: 10px; }

    @media(max-width: 900px) { .grid-3 { grid-template-columns: repeat(2,1fr); } .grid-2 { grid-template-columns: 1fr; } }
    @media(max-width: 600px) { .grid-3, .grid-4 { grid-template-columns: 1fr; } .site-nav { display: none; } .topbar-inner { justify-content: center; } .topbar-left { display: none; } }

    /* ─── FOOTER ─── */
    .site-footer { background: #1d1d1d; color: rgba(255,255,255,.55); padding: 56px 0 28px; }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; padding-bottom: 40px; border-bottom: 1px solid rgba(255,255,255,.1); }
    .footer-grid h4 { color: white; font-size: 14px; font-weight: 700; margin-bottom: 16px; }
    .footer-grid a { color: rgba(255,255,255,.5); text-decoration: none; display: block; font-size: 13.5px; margin-bottom: 8px; transition: color .15s; }
    .footer-grid a:hover { color: var(--blue); }
    .footer-logo { font-size: 20px; font-weight: 900; color: white; margin-bottom: 12px; }
    .footer-logo .accent { color: var(--blue); }
    .footer-desc { font-size: 13.5px; line-height: 1.7; margin-bottom: 20px; }
    .footer-phone { color: var(--orange) !important; font-weight: 700; font-size: 16px !important; }
    .footer-bottom { display: flex; justify-content: space-between; align-items: center; padding-top: 24px; font-size: 13px; flex-wrap: wrap; gap: 8px; }
    .footer-bottom a { color: rgba(255,255,255,.35); font-size: 13px; text-decoration: none; }
    .footer-bottom a:hover { color: var(--blue); }

    @media(max-width: 768px) { .footer-grid { grid-template-columns: 1fr 1fr; } }
    @media(max-width: 480px) { .footer-grid { grid-template-columns: 1fr; } }

    /* ─── CONTENT PAGES ─── */
    .page-hero { background: var(--blue); color: white; padding: 64px 0 72px; }
    .page-hero h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; margin-bottom: 16px; letter-spacing: -1px; }
    .page-hero p { font-size: 18px; opacity: .9; max-width: 600px; }

    .prose { max-width: 780px; margin: 0 auto; padding: 64px 24px; }
    .prose h2 { font-size: 1.6rem; font-weight: 800; color: var(--blue-dark); margin: 48px 0 16px; }
    .prose h2:first-child { margin-top: 0; }
    .prose p { font-size: 16.5px; color: var(--text-light); line-height: 1.8; margin-bottom: 20px; }
    .prose ul { margin: 0 0 20px 0; padding-left: 0; list-style: none; }
    .prose li { padding: 8px 0 8px 28px; position: relative; font-size: 16px; color: var(--text-light); border-bottom: 1px solid var(--border); }
    .prose li::before { content: "✓"; position: absolute; left: 0; color: var(--blue); font-weight: 800; }
    .prose a { color: var(--orange); }
  </style>
  <!-- Google Analytics GA4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-D2PYH7F61N"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-D2PYH7F61N');
  </script>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
</head>
<body>
  <!-- TOP BAR -->
  <div class="topbar">
    <div class="container">
      <div class="topbar-inner">
        <span class="topbar-left">📍 Your Local Wichita Cash Home Buyer</span>
        <a href="tel:3163683344">Call or Text Us (316) 368-3344</a>
      </div>
    </div>
  </div>

  <!-- HEADER -->
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo">Jacob<span class="logo-buys">Buys</span>YourHouse<span class="logo-com">.com</span></a>
      <nav class="site-nav">
        <a href="/about">About Jacob</a>
        <a href="/how-it-works">How It Works</a>
        <a href="/areas">Areas We Serve</a>
        <a href="/blog">Blog</a>
        <a href="/contact" class="btn-nav">Get Your Offer →</a>
      </nav>
    </div>
  </header>

  <slot />

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div>
          <div class="footer-logo"><img src="/logo-nav.png" alt="Jacob Buys Your House" height="72" style="display:block" /></div>
          <p class="footer-desc">Local cash home buyer serving Wichita, KS and surrounding communities. We buy houses fast, as-is, for a fair price. No fees, no repairs, no hassle.</p>
          <a href="tel:3163683344" class="footer-phone">(316) 368-3344</a>
        </div>
        <div>
          <h4>Situations</h4>
          <a href="/sell/inherited-house">Inherited Property</a>
          <a href="/sell/foreclosure">Stop Foreclosure</a>
          <a href="/sell/divorce">Divorce</a>
          <a href="/sell/as-is">Sell As-Is</a>
          <a href="/sell/rental-property">Tired Landlord</a>
          <a href="/sell/behind-on-taxes">Tax Problems</a>
          <a href="/sell/probate">Probate</a>
        </div>
        <div>
          <h4>Areas</h4>
          <a href="/areas/wichita">Wichita</a>
          <a href="/areas/derby">Derby</a>
          <a href="/areas/mulvane">Mulvane</a>
          <a href="/areas/haysville">Haysville</a>
          <a href="/areas/andover">Andover</a>
          <a href="/areas/augusta">Augusta</a>
          <a href="/areas/el-dorado">El Dorado</a>
        </div>
        <div>
          <h4>Company</h4>
          <a href="/how-it-works">How It Works</a>
          <a href="/about">About Jacob</a>
          <a href="/faq">FAQ</a>
          <a href="/blog">Blog</a>
          <a href="/contact">Contact</a>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© {new Date().getFullYear()} Jacob Buys Your House · Wichita, KS</span>
        <a href="/privacy">Privacy Policy</a>
      </div>
    </div>
  </footer>
</body>
</html>
