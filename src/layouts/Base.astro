---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
}
const { title, description, canonical } = Astro.props;
const url = canonical || Astro.url.href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="robots" content="index, follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    
    :root {
      --green: #1a4731;
      --green-dark: #0f2d1f;
      --green-light: #f0f7f3;
      --orange: #e07820;
      --orange-dark: #c4651a;
      --gold: #f5c842;
      --gray: #64748b;
      --gray-light: #f8fafc;
      --white: #ffffff;
      --text: #1e293b;
      --text-light: #475569;
      --border: #e2e8f0;
      --shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.06);
      --shadow-lg: 0 4px 6px rgba(0,0,0,.05), 0 10px 40px rgba(0,0,0,.1);
    }

    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); line-height: 1.6; background: white; -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    a { color: var(--orange); }

    .container { max-width: 1140px; margin: 0 auto; padding: 0 24px; }

    /* ─── TOP BAR ─── */
    .topbar {
      background: var(--green-dark);
      color: rgba(255,255,255,.85);
      font-size: 13px;
      font-weight: 500;
      padding: 9px 0;
    }
    .topbar-inner { display: flex; justify-content: space-between; align-items: center; gap: 16px; }
    .topbar a { color: var(--gold); font-weight: 700; text-decoration: none; font-size: 14px; }
    .topbar a:hover { color: white; }

    /* ─── HEADER ─── */
    .site-header {
      background: white;
      padding: 0;
      position: sticky;
      top: 0;
      z-index: 200;
      border-bottom: 1px solid var(--border);
      box-shadow: 0 1px 12px rgba(0,0,0,.08);
    }
    .header-inner { display: flex; justify-content: space-between; align-items: center; height: 72px; }
    .logo { font-size: 18px; font-weight: 900; color: var(--text); text-decoration: none; letter-spacing: -0.5px; line-height: 1.2; }
    .logo .dot { color: var(--orange); }
    .logo .com { color: var(--gray); font-weight: 500; font-size: 14px; }
    .site-nav { display: flex; align-items: center; gap: 8px; }
    .site-nav a { color: var(--text-light); text-decoration: none; font-size: 14px; font-weight: 500; padding: 8px 12px; border-radius: 6px; transition: all .15s; white-space: nowrap; }
    .site-nav a:hover { color: var(--green); background: var(--green-light); }
    .btn-nav {
      background: var(--orange);
      color: white !important;
      font-weight: 700 !important;
      padding: 10px 22px !important;
      border-radius: 8px;
      font-size: 14px;
      white-space: nowrap;
      transition: background .15s !important;
    }
    .btn-nav:hover { background: var(--orange-dark) !important; color: white !important; }

    /* ─── BUTTONS ─── */
    .btn-primary {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--orange); color: white; font-weight: 700;
      font-size: 16px; padding: 16px 36px; border-radius: 10px;
      text-decoration: none; transition: all .2s;
      box-shadow: 0 4px 14px rgba(224,120,32,.4);
      white-space: nowrap;
    }
    .btn-primary:hover { background: var(--orange-dark); color: white; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(224,120,32,.5); }
    
    .btn-secondary {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(255,255,255,.12); color: white; font-weight: 600;
      font-size: 15px; padding: 15px 32px; border-radius: 10px;
      text-decoration: none; border: 1.5px solid rgba(255,255,255,.4);
      transition: all .2s; white-space: nowrap;
      backdrop-filter: blur(4px);
    }
    .btn-secondary:hover { background: rgba(255,255,255,.22); color: white; }

    .btn-dark {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--green-dark); color: white; font-weight: 700;
      font-size: 16px; padding: 16px 40px; border-radius: 10px;
      text-decoration: none; transition: all .2s;
    }
    .btn-dark:hover { background: black; color: white; transform: translateY(-1px); }

    /* ─── SECTIONS ─── */
    .section { padding: 88px 0; }
    .section-sm { padding: 60px 0; }
    .bg-light { background: var(--gray-light); }
    .bg-green { background: var(--green); }
    .bg-green-dark { background: var(--green-dark); }
    .bg-white { background: white; }

    .eyebrow {
      display: inline-block;
      font-size: 11px; font-weight: 700; letter-spacing: 2.5px;
      text-transform: uppercase; color: var(--orange);
      margin-bottom: 12px;
    }
    .eyebrow-light { color: var(--gold); }

    .section-title { font-size: clamp(1.75rem, 3.5vw, 2.4rem); font-weight: 800; color: var(--text); line-height: 1.2; margin-bottom: 16px; }
    .section-title-white { color: white; }
    .section-sub { font-size: 17px; color: var(--text-light); max-width: 620px; line-height: 1.7; }
    .section-sub-white { color: rgba(255,255,255,.8); }

    .text-center { text-align: center; }
    .text-center .section-sub { margin: 0 auto; }

    /* ─── CARDS ─── */
    .card {
      background: white;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 32px;
      box-shadow: var(--shadow);
      transition: box-shadow .2s, transform .2s;
    }
    .card:hover { box-shadow: var(--shadow-lg); transform: translateY(-2px); }

    /* ─── GRID HELPERS ─── */
    .grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; }
    .grid-4 { display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; }
    .grid-2 { display: grid; grid-template-columns: repeat(2,1fr); gap: 32px; align-items: center; }
    .grid-areas { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px,1fr)); gap: 10px; }

    @media(max-width: 900px) {
      .grid-3 { grid-template-columns: repeat(2,1fr); }
      .grid-2 { grid-template-columns: 1fr; }
    }
    @media(max-width: 600px) {
      .grid-3, .grid-4 { grid-template-columns: 1fr; }
      .site-nav { display: none; }
      .topbar-inner { justify-content: center; }
      .topbar-left { display: none; }
    }

    /* ─── FOOTER ─── */
    .site-footer { background: #0a1810; color: rgba(255,255,255,.6); padding: 56px 0 28px; }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; padding-bottom: 40px; border-bottom: 1px solid rgba(255,255,255,.1); }
    .footer-grid h4 { color: white; font-size: 14px; font-weight: 700; margin-bottom: 16px; letter-spacing: .3px; }
    .footer-grid a { color: rgba(255,255,255,.55); text-decoration: none; display: block; font-size: 13.5px; margin-bottom: 8px; transition: color .15s; }
    .footer-grid a:hover { color: var(--orange); }
    .footer-logo { font-size: 20px; font-weight: 900; color: white; margin-bottom: 12px; }
    .footer-logo .dot { color: var(--orange); }
    .footer-desc { font-size: 13.5px; line-height: 1.7; margin-bottom: 20px; }
    .footer-phone { color: var(--gold) !important; font-weight: 700; font-size: 16px !important; }
    .footer-bottom { display: flex; justify-content: space-between; align-items: center; padding-top: 24px; font-size: 13px; flex-wrap: wrap; gap: 8px; }
    .footer-bottom a { color: rgba(255,255,255,.4); font-size: 13px; text-decoration: none; }
    .footer-bottom a:hover { color: var(--orange); }

    @media(max-width: 768px) {
      .footer-grid { grid-template-columns: 1fr 1fr; }
      .footer-bottom { justify-content: center; text-align: center; }
    }
    @media(max-width: 480px) {
      .footer-grid { grid-template-columns: 1fr; }
    }

    /* ─── CONTENT PAGES ─── */
    .page-hero { background: linear-gradient(135deg, var(--green-dark) 0%, var(--green) 100%); color: white; padding: 64px 0 72px; }
    .page-hero h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; margin-bottom: 16px; }
    .page-hero p { font-size: 18px; opacity: .88; max-width: 600px; }

    .prose { max-width: 780px; margin: 0 auto; padding: 64px 24px; }
    .prose h2 { font-size: 1.6rem; font-weight: 800; color: var(--green); margin: 48px 0 16px; }
    .prose h2:first-child { margin-top: 0; }
    .prose p { font-size: 16.5px; color: var(--text-light); line-height: 1.8; margin-bottom: 20px; }
    .prose ul { margin: 0 0 20px 0; padding-left: 0; list-style: none; }
    .prose li { padding: 8px 0 8px 28px; position: relative; font-size: 16px; color: var(--text-light); border-bottom: 1px solid var(--border); }
    .prose li::before { content: "✓"; position: absolute; left: 0; color: var(--green); font-weight: 700; }
    .prose a { color: var(--orange); }
  </style>
</head>
<body>
  <!-- TOP BAR -->
  <div class="topbar">
    <div class="container">
      <div class="topbar-inner">
        <span class="topbar-left">📍 Your Local Wichita Cash Home Buyer — Wichita, KS</span>
        <a href="tel:3168162983">📞 Call or Text (316) 816-2983</a>
      </div>
    </div>
  </div>

  <!-- HEADER -->
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo">
        Jacob<span class="dot">·</span>Buys<span class="dot">·</span>YourHouse<span class="com">.com</span>
      </a>
      <nav class="site-nav">
        <a href="/about">About Jacob</a>
        <a href="/how-it-works">How It Works</a>
        <a href="/areas">Areas We Serve</a>
        <a href="/blog">Blog</a>
        <a href="/contact" class="btn-nav">Get Your Offer →</a>
      </nav>
    </div>
  </header>

  <slot />

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div>
          <div class="footer-logo">Jacob<span class="dot">·</span>BuysYourHouse</div>
          <p class="footer-desc">Local cash home buyer serving Wichita, KS and surrounding communities. We buy houses fast, as-is, for a fair price. No fees, no repairs, no hassle.</p>
          <a href="tel:3168162983" class="footer-phone">(316) 816-2983</a>
        </div>
        <div>
          <h4>Situations</h4>
          <a href="/sell/inherited-house">Inherited Property</a>
          <a href="/sell/foreclosure">Stop Foreclosure</a>
          <a href="/sell/divorce">Divorce</a>
          <a href="/sell/as-is">Sell As-Is</a>
          <a href="/sell/rental-property">Tired Landlord</a>
          <a href="/sell/behind-on-taxes">Tax Problems</a>
          <a href="/sell/probate">Probate</a>
        </div>
        <div>
          <h4>Areas</h4>
          <a href="/areas/wichita">Wichita</a>
          <a href="/areas/derby">Derby</a>
          <a href="/areas/mulvane">Mulvane</a>
          <a href="/areas/haysville">Haysville</a>
          <a href="/areas/andover">Andover</a>
          <a href="/areas/augusta">Augusta</a>
          <a href="/areas/el-dorado">El Dorado</a>
        </div>
        <div>
          <h4>Company</h4>
          <a href="/how-it-works">How It Works</a>
          <a href="/about">About Jacob</a>
          <a href="/faq">FAQ</a>
          <a href="/blog">Blog</a>
          <a href="/contact">Contact</a>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© {new Date().getFullYear()} Jacob Buys Your House · Wichita, KS</span>
        <a href="/privacy">Privacy Policy</a>
      </div>
    </div>
  </footer>
</body>
</html>
