---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
}
const { title, description, canonical } = Astro.props;
const url = canonical || Astro.url.href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={url} />
  <meta name="robots" content="index, follow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: #1a1a1a; line-height: 1.6; }
    a { color: #1a5c3a; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }

    /* HEADER */
    header { background: #1a5c3a; color: white; padding: 16px 0; position: sticky; top: 0; z-index: 100; box-shadow: 0 2px 8px rgba(0,0,0,.2); }
    .header-inner { display: flex; justify-content: space-between; align-items: center; }
    .logo { font-size: 1.4rem; font-weight: 800; color: white; text-decoration: none; }
    .logo span { color: #f0c040; }
    .phone-header { font-size: 1.1rem; font-weight: 700; color: #f0c040; text-decoration: none; }
    nav a { color: white; text-decoration: none; margin-left: 20px; font-size: .95rem; }
    nav a:hover { color: #f0c040; }

    /* HERO */
    .hero { background: linear-gradient(135deg, #1a5c3a 0%, #0d3a24 100%); color: white; padding: 80px 0; text-align: center; }
    .hero h1 { font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 900; margin-bottom: 20px; line-height: 1.2; }
    .hero p { font-size: 1.2rem; max-width: 650px; margin: 0 auto 32px; opacity: .9; }
    .btn-primary { display: inline-block; background: #f0c040; color: #1a1a1a; font-weight: 800; font-size: 1.1rem; padding: 18px 40px; border-radius: 6px; text-decoration: none; transition: transform .15s; }
    .btn-primary:hover { transform: translateY(-2px); background: #e0b030; color: #1a1a1a; }
    .btn-secondary { display: inline-block; background: transparent; border: 2px solid white; color: white; font-weight: 700; font-size: 1rem; padding: 14px 32px; border-radius: 6px; text-decoration: none; margin-left: 16px; }

    /* STEPS */
    .steps { padding: 70px 0; background: #f9f9f9; }
    .steps h2 { text-align: center; font-size: 2rem; margin-bottom: 48px; color: #1a5c3a; }
    .steps-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 32px; }
    .step { text-align: center; padding: 32px 24px; background: white; border-radius: 10px; box-shadow: 0 2px 12px rgba(0,0,0,.06); }
    .step-num { width: 52px; height: 52px; background: #1a5c3a; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; font-weight: 900; margin: 0 auto 16px; }
    .step h3 { font-size: 1.1rem; margin-bottom: 10px; }

    /* SECTIONS */
    .section { padding: 70px 0; }
    .section-alt { background: #f4f8f5; }
    .section h2 { font-size: 1.9rem; color: #1a5c3a; margin-bottom: 20px; }
    .section p { font-size: 1.05rem; margin-bottom: 16px; color: #333; }
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
    @media(max-width:768px){ .two-col { grid-template-columns: 1fr; } nav { display: none; } }

    /* SITUATIONS */
    .situations-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-top: 32px; }
    .situation-card { background: white; border: 1px solid #e0e8e4; border-radius: 8px; padding: 24px; }
    .situation-card h3 { color: #1a5c3a; font-size: 1.05rem; margin-bottom: 8px; }
    .situation-card a { display: block; margin-top: 12px; font-weight: 600; font-size: .9rem; }

    /* AREAS */
    .areas-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 16px; margin-top: 32px; }
    .area-card { background: #1a5c3a; color: white; border-radius: 8px; padding: 20px; text-align: center; text-decoration: none; font-weight: 700; transition: background .15s; }
    .area-card:hover { background: #0d3a24; color: white; }

    /* FAQ */
    .faq { padding: 70px 0; }
    .faq h2 { font-size: 1.9rem; color: #1a5c3a; margin-bottom: 40px; text-align: center; }
    .faq-item { border-bottom: 1px solid #e0e0e0; padding: 20px 0; }
    .faq-item h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 10px; }
    .faq-item p { color: #555; }

    /* TRUST */
    .trust { background: #1a5c3a; color: white; padding: 60px 0; text-align: center; }
    .trust h2 { font-size: 1.9rem; margin-bottom: 16px; }
    .trust p { font-size: 1.1rem; opacity: .9; margin-bottom: 32px; }
    .trust-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 32px; margin: 40px 0; }
    .trust-stat { }
    .trust-stat .num { font-size: 2.8rem; font-weight: 900; color: #f0c040; }
    .trust-stat .label { font-size: .95rem; opacity: .85; }

    /* FOOTER */
    footer { background: #111; color: #aaa; padding: 40px 0; }
    .footer-inner { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 32px; }
    footer h4 { color: white; margin-bottom: 12px; }
    footer a { color: #aaa; text-decoration: none; display: block; margin-bottom: 6px; }
    footer a:hover { color: #f0c040; }
    .footer-bottom { text-align: center; margin-top: 32px; padding-top: 20px; border-top: 1px solid #333; font-size: .85rem; }

    /* CTA BLOCK */
    .cta-block { background: #f0c040; padding: 60px 0; text-align: center; }
    .cta-block h2 { font-size: 2rem; color: #1a1a1a; margin-bottom: 12px; }
    .cta-block p { font-size: 1.1rem; color: #333; margin-bottom: 28px; }
    .btn-dark { display: inline-block; background: #1a5c3a; color: white; font-weight: 800; font-size: 1.1rem; padding: 18px 40px; border-radius: 6px; text-decoration: none; }

    /* CONTENT PAGE */
    .content-page { padding: 60px 0; max-width: 820px; margin: 0 auto; }
    .content-page h1 { font-size: 2.2rem; color: #1a5c3a; margin-bottom: 24px; line-height: 1.3; }
    .content-page h2 { font-size: 1.5rem; color: #1a5c3a; margin: 40px 0 16px; }
    .content-page p { margin-bottom: 18px; font-size: 1.05rem; line-height: 1.75; color: #333; }
    .content-page ul { margin: 0 0 18px 24px; }
    .content-page li { margin-bottom: 8px; font-size: 1.05rem; color: #333; }
  </style>
</head>
<body>
  <header>
    <div class="container header-inner">
      <a href="/" class="logo">Jacob <span>Buys</span> Your House</a>
      <nav>
        <a href="/areas">Areas We Serve</a>
        <a href="/sell">Situations</a>
        <a href="/blog">Blog</a>
        <a href="/about">About Jacob</a>
        <a href="/contact">Contact</a>
      </nav>
      <a href="tel:3168162983" class="phone-header">(316) 816-2983</a>
    </div>
  </header>
  <slot />
  <footer>
    <div class="container">
      <div class="footer-inner">
        <div>
          <h4>Jacob Buys Your House</h4>
          <p style="font-size:.9rem;margin-bottom:12px;">Local cash home buyers in Wichita, KS. We buy houses fast, as-is, for a fair price.</p>
          <a href="tel:3168162983" style="color:#f0c040;font-weight:700;">(316) 816-2983</a>
        </div>
        <div>
          <h4>Situations We Help With</h4>
          <a href="/sell/inherited-house">Inherited Property</a>
          <a href="/sell/foreclosure">Stopping Foreclosure</a>
          <a href="/sell/divorce">Going Through Divorce</a>
          <a href="/sell/as-is">Selling As-Is</a>
          <a href="/sell/rental-property">Tired Landlords</a>
          <a href="/sell/behind-on-taxes">Behind on Taxes</a>
        </div>
        <div>
          <h4>Areas We Serve</h4>
          <a href="/areas/wichita">Wichita, KS</a>
          <a href="/areas/derby">Derby, KS</a>
          <a href="/areas/mulvane">Mulvane, KS</a>
          <a href="/areas/haysville">Haysville, KS</a>
          <a href="/areas/andover">Andover, KS</a>
          <a href="/areas/augusta">Augusta, KS</a>
          <a href="/areas/el-dorado">El Dorado, KS</a>
        </div>
        <div>
          <h4>Quick Links</h4>
          <a href="/how-it-works">How It Works</a>
          <a href="/about">About Jacob</a>
          <a href="/reviews">Reviews</a>
          <a href="/blog">Blog</a>
          <a href="/contact">Contact Us</a>
          <a href="/faq">FAQ</a>
        </div>
      </div>
      <div class="footer-bottom">
        &copy; {new Date().getFullYear()} Jacob Buys Your House · Wichita, KS · <a href="/privacy">Privacy Policy</a>
      </div>
    </div>
  </footer>
</body>
</html>
