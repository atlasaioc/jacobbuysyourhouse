---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  heroImage: string;
  category: string;
  date: string;
  readTime: string;
}
const { title, description, canonical, heroImage, category, date, readTime } = Astro.props;
const url = canonical || Astro.url.href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`https://jacobbuysyourhouse.com${heroImage}`} />
  <meta property="og:type" content="article" />
  <meta name="robots" content="index, follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --blue: #3aa1f8; --blue-dark: #1a82d8; --blue-deeper: #0d5fa0;
      --blue-light: #e8f5ff; --blue-mid: #cce8ff;
      --orange: #e87122; --orange-dark: #c45a12;
      --white: #fff; --text: #1d1d1d; --text-light: #555;
      --gray: #888; --gray-light: #f3f5f8; --border: #e0e8f0;
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); line-height: 1.6; background: white; -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    .container { max-width: 1140px; margin: 0 auto; padding: 0 24px; }

    /* TOP BAR */
    .topbar { background: #1d1d1d; color: rgba(255,255,255,.8); font-size: 13px; padding: 9px 0; }
    .topbar-inner { display: flex; justify-content: space-between; align-items: center; }
    .topbar a { color: var(--blue); font-weight: 700; text-decoration: none; }
    .topbar a:hover { color: white; }
    @media(max-width:600px){ .topbar-left{display:none;} .topbar-inner{justify-content:center;} }

    /* HEADER */
    .site-header { background: white; position: sticky; top: 0; z-index: 200; border-bottom: 1px solid var(--border); box-shadow: 0 2px 12px rgba(0,0,0,.06); }
    .header-inner { display: flex; justify-content: space-between; align-items: center; height: 72px; }
    .accent { color: #3aa1f8; }
    .com { color: #999; font-weight: 500; font-size: 14px; }
    .logo { font-size: 24px; font-weight: 900; color: var(--text); text-decoration: none; letter-spacing: -0.4px; }
    .logo-buys { color: #3aa1f8; }
    .logo .com { color: var(--gray); font-weight: 500; font-size: 13px; }
    .site-nav { display: flex; align-items: center; gap: 4px; }
    .site-nav a { color: var(--text-light); text-decoration: none; font-size: 14px; font-weight: 500; padding: 8px 12px; border-radius: 6px; transition: all .15s; white-space: nowrap; }
    .site-nav a:hover { color: var(--blue); background: var(--blue-light); }
    .btn-nav { background: var(--orange) !important; color: white !important; font-weight: 700 !important; padding: 10px 22px !important; border-radius: 7px; }
    .btn-nav:hover { background: var(--orange-dark) !important; }
    @media(max-width:768px){ .site-nav { display: none; } }

    /* ARTICLE HERO */
    .article-hero {
      position: relative; min-height: 460px;
      display: flex; align-items: flex-end; overflow: hidden;
    }
    .article-hero-bg {
      position: absolute; inset: 0;
      background-size: cover; background-position: center;
      filter: brightness(.38); transform: scale(1.03);
    }
    .article-hero-content {
      position: relative; z-index: 2;
      padding: 64px 0 52px; width: 100%; color: white;
    }
    .article-breadcrumb { font-size: 13px; color: rgba(255,255,255,.6); margin-bottom: 16px; display: flex; gap: 8px; align-items: center; }
    .article-breadcrumb a { color: rgba(255,255,255,.6); text-decoration: none; }
    .article-breadcrumb a:hover { color: white; }
    .article-breadcrumb span { color: rgba(255,255,255,.35); }
    .article-category {
      display: inline-block; background: var(--orange);
      color: white; font-size: 11px; font-weight: 700;
      letter-spacing: 1.5px; text-transform: uppercase;
      padding: 5px 12px; border-radius: 6px; margin-bottom: 16px;
    }
    .article-hero h1 {
      font-size: clamp(1.8rem, 3.8vw, 2.9rem);
      font-weight: 900; line-height: 1.15;
      max-width: 820px; margin-bottom: 20px; letter-spacing: -1px;
    }
    .article-meta { display: flex; gap: 20px; align-items: center; flex-wrap: wrap; }
    .article-meta span { font-size: 13.5px; color: rgba(255,255,255,.7); display: flex; align-items: center; gap: 6px; font-weight: 500; }

    /* ARTICLE BODY */
    .article-body { padding: 64px 0 80px; }
    .article-layout { display: grid; grid-template-columns: 1fr 340px; gap: 56px; align-items: start; }
    @media(max-width:1000px){ .article-layout { grid-template-columns: 1fr; } .article-sidebar { display: none; } }

    /* PROSE */
    .article-prose { max-width: 720px; }
    .article-prose h2 { font-size: 1.45rem; font-weight: 800; color: var(--blue-dark); margin: 44px 0 14px; padding-top: 8px; border-top: 2px solid var(--blue-light); }
    .article-prose h2:first-child { margin-top: 0; border-top: none; padding-top: 0; }
    .article-prose h3 { font-size: 1.1rem; font-weight: 700; color: var(--text); margin: 28px 0 10px; }
    .article-prose p { font-size: 16.5px; color: #333; line-height: 1.85; margin-bottom: 20px; }
    .article-prose ul, .article-prose ol { margin: 0 0 20px; padding-left: 0; list-style: none; }
    .article-prose li { font-size: 16px; color: #444; padding: 9px 0 9px 28px; position: relative; border-bottom: 1px solid #f0f4f8; line-height: 1.65; }
    .article-prose li:last-child { border: none; }
    .article-prose li::before { content: "✓"; position: absolute; left: 0; color: var(--blue); font-weight: 800; }
    .article-prose a { color: var(--orange); font-weight: 600; }
    .article-prose strong { color: var(--text); }

    /* CALLOUT BOX */
    .callout { background: var(--blue-light); border-left: 4px solid var(--blue); border-radius: 0 12px 12px 0; padding: 20px 24px; margin: 28px 0; }
    .callout p { font-size: 15.5px; color: var(--blue-deeper); margin: 0; font-weight: 500; }

    /* AUTHOR BOX */
    .author-box { background: var(--gray-light); border: 1px solid var(--border); border-radius: 16px; padding: 28px; display: flex; gap: 20px; align-items: flex-start; margin-top: 48px; }
    .author-avatar { width: 64px; height: 64px; min-width: 64px; background: var(--blue); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; color: white; font-weight: 900; }
    .author-info h4 { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
    .author-info p { font-size: 14px; color: var(--text-light); margin: 0; line-height: 1.6; }

    /* SIDEBAR */
    .article-sidebar { position: sticky; top: 96px; }
    .sidebar-cta { background: var(--blue); border-radius: 18px; padding: 30px 26px; color: white; margin-bottom: 20px; }
    .sidebar-cta h3 { font-size: 1.1rem; font-weight: 800; margin-bottom: 10px; }
    .sidebar-cta p { font-size: 14px; opacity: .88; margin-bottom: 22px; line-height: 1.6; }
    .sidebar-phone { display: block; background: var(--orange); color: white; font-weight: 800; font-size: 1.05rem; text-align: center; padding: 15px; border-radius: 10px; text-decoration: none; margin-bottom: 10px; box-shadow: 0 4px 14px rgba(232,113,34,.4); transition: all .2s; }
    .sidebar-phone:hover { background: var(--orange-dark); color: white; }
    .sidebar-link { display: block; background: rgba(255,255,255,.15); border: 1px solid rgba(255,255,255,.3); color: white; font-weight: 600; font-size: 13.5px; text-align: center; padding: 12px; border-radius: 10px; text-decoration: none; transition: all .2s; }
    .sidebar-link:hover { background: rgba(255,255,255,.25); color: white; }
    .sidebar-bullets { list-style: none; margin: 18px 0 0; padding: 0; border-top: 1px solid rgba(255,255,255,.2); padding-top: 18px; }
    .sidebar-bullets li { font-size: 13px; color: rgba(255,255,255,.88); padding: 4px 0 4px 18px; position: relative; }
    .sidebar-bullets li::before { content: "✓"; position: absolute; left: 0; font-weight: 800; color: rgba(255,255,255,.65); }

    .related-posts { background: var(--gray-light); border-radius: 14px; padding: 22px; border: 1px solid var(--border); }
    .related-posts h4 { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text); margin-bottom: 14px; }
    .related-link { display: flex; gap: 10px; align-items: flex-start; padding: 10px 0; border-bottom: 1px solid var(--border); text-decoration: none; }
    .related-link:last-child { border: none; padding-bottom: 0; }
    .related-link .rl-img { width: 56px; height: 44px; border-radius: 6px; object-fit: cover; flex-shrink: 0; }
    .related-link .rl-text { font-size: 13px; font-weight: 600; color: var(--blue-dark); line-height: 1.4; }
    .related-link:hover .rl-text { color: var(--orange); }

    /* BOTTOM CTA */
    .bottom-cta { background: var(--orange); padding: 72px 0; text-align: center; position: relative; overflow: hidden; }
    .bottom-cta::before { content:''; position:absolute; top:-50%; right:-5%; width:500px; height:500px; background:radial-gradient(circle,rgba(255,255,255,.1) 0%,transparent 60%); }
    .bottom-cta h2 { font-size: clamp(1.8rem,3.5vw,2.5rem); font-weight: 900; color: white; margin-bottom: 12px; position: relative; letter-spacing: -.5px; }
    .bottom-cta p { font-size: 17px; color: rgba(255,255,255,.88); margin-bottom: 36px; position: relative; }
    .btn-white { display: inline-flex; align-items: center; gap: 8px; background: white; color: var(--orange); font-weight: 800; font-size: 17px; padding: 18px 48px; border-radius: 8px; text-decoration: none; box-shadow: 0 4px 20px rgba(0,0,0,.15); transition: all .2s; position: relative; }
    .btn-white:hover { background: #1d1d1d; color: white; transform: translateY(-2px); }

    /* FOOTER */
    .site-footer { background: #1d1d1d; color: rgba(255,255,255,.55); padding: 56px 0 28px; }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; padding-bottom: 40px; border-bottom: 1px solid rgba(255,255,255,.1); }
    .footer-grid h4 { color: white; font-size: 14px; font-weight: 700; margin-bottom: 16px; }
    .footer-grid a { color: rgba(255,255,255,.5); text-decoration: none; display: block; font-size: 13.5px; margin-bottom: 8px; }
    .footer-grid a:hover { color: var(--blue); }
    .footer-logo { font-size: 20px; font-weight: 900; color: white; margin-bottom: 12px; }
    .footer-logo .accent { color: var(--blue); }
    .footer-desc { font-size: 13.5px; line-height: 1.7; margin-bottom: 20px; }
    .footer-phone { color: var(--orange) !important; font-weight: 700; font-size: 16px !important; }
    .footer-bottom { display: flex; justify-content: space-between; padding-top: 24px; font-size: 13px; flex-wrap: wrap; gap: 8px; }
    .footer-bottom a { color: rgba(255,255,255,.35); font-size: 13px; text-decoration: none; }
    .footer-bottom a:hover { color: var(--blue); }
    @media(max-width:768px){ .footer-grid { grid-template-columns: 1fr 1fr; } }
    @media(max-width:480px){ .footer-grid { grid-template-columns: 1fr; } }
  </style>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
</head>
<body>
  <div class="topbar">
    <div class="container">
      <div class="topbar-inner">
        <span class="topbar-left">📍 Your Local Wichita Cash Home Buyer</span>
        <a href="tel:3163683344">Call or Text (316) 368-3344</a>
      </div>
    </div>
  </div>

  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo">Jacob<span class="accent">Buys</span>YourHouse<span class="com">.com</span></a>
      <nav class="site-nav">
        <a href="/about">About Jacob</a>
        <a href="/how-it-works">How It Works</a>
        <a href="/areas">Areas We Serve</a>
        <a href="/blog">Blog</a>
        <a href="/contact" class="btn-nav">Get Your Offer →</a>
      </nav>
    </div>
  </header>

  <!-- ARTICLE HERO -->
  <section class="article-hero">
    <div class="article-hero-bg" style={`background-image:url('${heroImage}')`}></div>
    <div class="container article-hero-content">
      <div class="article-breadcrumb">
        <a href="/">Home</a><span>›</span>
        <a href="/blog">Blog</a><span>›</span>
        <span style="color:rgba(255,255,255,.9)">{category}</span>
      </div>
      <span class="article-category">{category}</span>
      <h1>{title}</h1>
      <div class="article-meta">
        <span>✍️ Jacob Buys Your House</span>
        <span>📅 {date}</span>
        <span>⏱ {readTime}</span>
      </div>
    </div>
  </section>

  <!-- ARTICLE BODY -->
  <div class="article-body">
    <div class="container">
      <div class="article-layout">

        <div class="article-prose">
          <slot />

          <!-- AUTHOR -->
          <div class="author-box">
            <div class="author-avatar">J</div>
            <div class="author-info">
              <h4>Jacob — Local Wichita Cash Home Buyer</h4>
              <p>Jacob buys houses in Wichita and surrounding communities. He answers his own phone and gives straight answers — even when the answer is that a cash sale isn't the right move for your situation.</p>
            </div>
          </div>
        </div>

        <!-- SIDEBAR -->
        <aside class="article-sidebar">
          <div class="sidebar-cta">
            <h3>Get Your Cash Offer</h3>
            <p>No obligation. No pressure. Fair offer within 24 hours.</p>
            <a href="tel:3163683344" class="sidebar-phone">📞 (316) 368-3344</a>
            <a href="/contact" class="sidebar-link">Submit Your Address →</a>
            <ul class="sidebar-bullets">
              <li>Offer within 24 hours</li>
              <li>Close in 7 days or less</li>
              <li>No repairs or cleaning</li>
              <li>Zero fees or commissions</li>
            </ul>
          </div>
          <div class="related-posts">
            <h4>Related Articles</h4>
            <a href="/blog/sell-inherited-house-wichita-ks" class="related-link">
              <img src="/situations/blog-inherited.jpg" alt="Inherited house" class="rl-img" loading="lazy"/>
              <span class="rl-text">How to Sell an Inherited House in Wichita, KS</span>
            </a>
            <a href="/blog/sell-house-as-is-wichita-ks" class="related-link">
              <img src="/situations/blog-as-is.jpg" alt="As-is house" class="rl-img" loading="lazy"/>
              <span class="rl-text">How to Sell a House As-Is in Wichita, KS</span>
            </a>
          </div>
        </aside>

      </div>
    </div>
  </div>

  <!-- BOTTOM CTA -->
  <section class="bottom-cta">
    <div class="container">
      <h2>Ready to Get Your Cash Offer?</h2>
      <p>Local buyer. Straight answers. Fast close. No hassle.</p>
      <a href="tel:3163683344" class="btn-white">📞 Call (316) 368-3344</a>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div>
          <div class="footer-logo">Jacob<span class="accent">Buys</span>YourHouse</div>
          <p class="footer-desc">Local cash home buyer serving Wichita, KS. No fees, no repairs, no hassle.</p>
          <a href="tel:3163683344" class="footer-phone">(316) 368-3344</a>
        </div>
        <div>
          <h4>Situations</h4>
          <a href="/sell/inherited-house">Inherited Property</a>
          <a href="/sell/foreclosure">Stop Foreclosure</a>
          <a href="/sell/divorce">Divorce</a>
          <a href="/sell/as-is">Sell As-Is</a>
          <a href="/sell/rental-property">Tired Landlord</a>
          <a href="/sell/behind-on-taxes">Tax Problems</a>
        </div>
        <div>
          <h4>Areas</h4>
          <a href="/areas/wichita">Wichita</a>
          <a href="/areas/derby">Derby</a>
          <a href="/areas/mulvane">Mulvane</a>
          <a href="/areas/haysville">Haysville</a>
          <a href="/areas/andover">Andover</a>
          <a href="/areas/augusta">Augusta</a>
        </div>
        <div>
          <h4>Company</h4>
          <a href="/how-it-works">How It Works</a>
          <a href="/about">About Jacob</a>
          <a href="/faq">FAQ</a>
          <a href="/blog">Blog</a>
          <a href="/contact">Contact</a>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© {new Date().getFullYear()} Jacob Buys Your House · Wichita, KS</span>
        <a href="/privacy">Privacy Policy</a>
      </div>
    </div>
  </footer>
</body>
</html>
