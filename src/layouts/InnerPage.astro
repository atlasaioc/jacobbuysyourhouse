---
// Reusable layout for all area + situation pages
import LeadForm from '../components/LeadForm.astro';
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  heroImage: string;       // path like /cities/wichita.jpg
  heroTitle: string;
  heroSub: string;
  breadcrumb?: string;     // e.g. "Areas We Serve"
  breadcrumbHref?: string;
}
const { title, description, canonical, heroImage, heroTitle, heroSub, breadcrumb, breadcrumbHref } = Astro.props;
const url = canonical || Astro.url.href.replace("www.jacobbuysyourhouse.com", "jacobbuysyourhouse.com");
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="robots" content="index, follow" />
  <meta property="og:url" content={url} />
  <meta property="og:image" content="https://jacobbuysyourhouse.com/og-image.jpg" />
  <meta property="og:site_name" content="Jacob Buys Your House" />
  <meta property="og:locale" content="en_US" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://jacobbuysyourhouse.com/og-image.jpg" />
  <meta name="geo.region" content="US-KS" />
  <meta name="geo.placename" content="Wichita, Kansas" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style is:global>
    /* inherit all global styles from Base.astro inline here */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --blue: #3aa1f8; --blue-dark: #1a82d8; --blue-deeper: #0d5fa0;
      --blue-light: #e8f5ff; --blue-mid: #cce8ff;
      --orange: #e87122; --orange-dark: #c45a12; --orange-light: #fff3eb;
      --white: #ffffff; --text: #1d1d1d; --text-light: #555;
      --gray: #888; --gray-light: #f3f5f8; --border: #e0e8f0;
      --shadow: 0 2px 12px rgba(58,161,248,.1), 0 1px 4px rgba(0,0,0,.06);
      --shadow-lg: 0 8px 40px rgba(58,161,248,.15), 0 2px 8px rgba(0,0,0,.06);
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); line-height: 1.6; background: white; -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    .container { max-width: 1140px; margin: 0 auto; padding: 0 24px; }

    /* TOP BAR */
    .topbar { background: #1d1d1d; color: rgba(255,255,255,.8); font-size: 13px; font-weight: 500; padding: 9px 0; }
    .topbar-inner { display: flex; justify-content: space-between; align-items: center; }
    .topbar a { color: var(--blue); font-weight: 700; text-decoration: none; font-size: 14px; }
    .topbar a:hover { color: white; }
    .topbar-left { }
    @media(max-width:600px){ .topbar-left { display:none; } .topbar-inner { justify-content:center; } }

    /* HEADER */
    .site-header { background: white; position: sticky; top: 0; z-index: 200; border-bottom: 1px solid var(--border); box-shadow: 0 2px 12px rgba(0,0,0,.06); }
    .header-inner { display: flex; justify-content: space-between; align-items: center; height: 72px; }
    .accent { color: #3aa1f8; }
    .com { color: #999; font-weight: 500; font-size: 14px; }
    .logo { font-size: 24px; font-weight: 900; color: var(--text); text-decoration: none; letter-spacing: -0.4px; }
    .logo-buys { color: #3aa1f8; }
    .logo .com { color: var(--gray); font-weight: 500; font-size: 13px; }
    .site-nav { display: flex; align-items: center; gap: 4px; }
    .site-nav a { color: var(--text-light); text-decoration: none; font-size: 14px; font-weight: 500; padding: 8px 12px; border-radius: 6px; transition: all .15s; white-space: nowrap; }
    .site-nav a:hover { color: var(--blue); background: var(--blue-light); }
    .btn-nav { background: var(--orange) !important; color: white !important; font-weight: 700 !important; padding: 10px 22px !important; border-radius: 7px; }
    .btn-nav:hover { background: var(--orange-dark) !important; }
    @media(max-width:768px){ .site-nav { display: none; } }

    /* PAGE HERO */
    .page-hero {
      position: relative;
      min-height: 420px;
      display: flex;
      align-items: flex-end;
      overflow: hidden;
    }
    .page-hero-bg {
      position: absolute; inset: 0;
      background-size: cover;
      background-position: center;
      filter: brightness(.42);
      transform: scale(1.03);
    }
    .page-hero-content {
      position: relative; z-index: 2;
      padding: 64px 0 56px;
      width: 100%;
      color: white;
    }
    .breadcrumb-row {
      display: flex; align-items: center; gap: 8px;
      font-size: 13px; color: rgba(255,255,255,.65);
      margin-bottom: 16px; font-weight: 500;
    }
    .breadcrumb-row a { color: rgba(255,255,255,.65); text-decoration: none; }
    .breadcrumb-row a:hover { color: white; }
    .breadcrumb-sep { color: rgba(255,255,255,.35); }
    .page-hero h1 {
      font-size: clamp(2rem, 4vw, 3.2rem);
      font-weight: 900; line-height: 1.1;
      margin-bottom: 14px; letter-spacing: -1px;
      max-width: 760px;
    }
    .page-hero p {
      font-size: 18px; opacity: .9;
      max-width: 600px; line-height: 1.65;
      margin-bottom: 32px;
    }
    .page-hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }
    .btn-primary { display: inline-flex; align-items: center; gap: 8px; background: var(--orange); color: white; font-weight: 700; font-size: 16px; padding: 14px 32px; border-radius: 8px; text-decoration: none; box-shadow: 0 4px 16px rgba(232,113,34,.4); transition: all .2s; white-space: nowrap; }
    .btn-primary:hover { background: var(--orange-dark); color: white; transform: translateY(-1px); }
    .btn-ghost { display: inline-flex; align-items: center; gap: 8px; background: white; border: none; color: #1d1d1d; font-weight: 700; font-size: 15px; padding: 13px 28px; border-radius: 8px; text-decoration: none; transition: all .2s; white-space: nowrap; box-shadow: 0 2px 10px rgba(0,0,0,.15); }
    .btn-ghost:hover { background: #f0f0f0; color: #1d1d1d; transform: translateY(-1px); }

    /* TRUST STRIP */
    .trust-strip { background: #1d1d1d; border-top: 3px solid var(--orange); }
    .trust-strip-inner { display: flex; justify-content: center; gap: 0; }
    .trust-item { display: flex; align-items: center; gap: 10px; padding: 18px 32px; border-right: 1px solid rgba(255,255,255,.08); }
    .trust-item:last-child { border-right: none; }
    .trust-icon { font-size: 1.4rem; }
    .trust-text .label { font-size: 13px; font-weight: 700; color: white; }
    .trust-text .sub { font-size: 11.5px; color: rgba(255,255,255,.5); }
    @media(max-width:700px){ .trust-strip-inner { flex-wrap: wrap; } .trust-item { flex: 0 0 50%; border-right: none; border-bottom: 1px solid rgba(255,255,255,.08); } }

    /* MAIN LAYOUT: content + sidebar */
    .page-body { padding: 64px 0 80px; }
    .page-layout { display: grid; grid-template-columns: 1fr 360px; gap: 56px; align-items: start; }
    @media(max-width: 1000px){ .page-layout { grid-template-columns: 1fr; } .page-sidebar { display: block; order: -1; position: static; } }

    /* CONTENT COLUMN */
    .page-content h2 { font-size: 1.5rem; font-weight: 800; color: var(--blue-dark); margin: 40px 0 14px; padding-top: 8px; border-top: 2px solid var(--blue-light); }
    .page-content h2:first-child { margin-top: 0; border-top: none; padding-top: 0; }
    .page-content p { font-size: 16px; color: #444; line-height: 1.8; margin-bottom: 16px; }
    .page-content a { color: var(--orange); }
    .page-content ul { list-style: none; margin: 0 0 20px; padding: 0; }
    .page-content li { font-size: 15.5px; color: #444; padding: 10px 0 10px 32px; position: relative; border-bottom: 1px solid #f0f4f8; }
    .page-content li:last-child { border: none; }
    .page-content li::before { content: "✓"; position: absolute; left: 0; color: var(--blue); font-weight: 800; font-size: 14px; top: 11px; }

    /* FEATURE BOXES */
    .feature-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 28px 0; }
    .feature-box { background: var(--blue-light); border: 1px solid var(--blue-mid); border-radius: 12px; padding: 20px; }
    .feature-box .icon { font-size: 1.6rem; margin-bottom: 8px; }
    .feature-box h3 { font-size: 14px; font-weight: 700; color: var(--blue-dark); margin-bottom: 4px; }
    .feature-box p { font-size: 13.5px; color: #555; margin: 0; line-height: 1.5; }
    @media(max-width:600px){ .feature-grid { grid-template-columns: 1fr; } }

    /* STEPS */
    .steps-list { margin: 28px 0; display: flex; flex-direction: column; gap: 0; }
    .step-row { display: flex; gap: 20px; align-items: flex-start; padding: 20px 0; border-bottom: 1px solid #f0f4f8; }
    .step-row:last-child { border: none; }
    .step-circle { width: 44px; height: 44px; min-width: 44px; background: var(--blue); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; font-weight: 900; box-shadow: 0 3px 10px rgba(58,161,248,.35); }
    .step-body h3 { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
    .step-body p { font-size: 14px; color: #555; margin: 0; line-height: 1.6; }

    /* SIDEBAR */
    .page-sidebar { position: sticky; top: 24px; align-self: start; }
    @media(max-width: 1000px){ .page-sidebar { position: static; top: auto; width: 100%; max-width: 480px; margin: 0 auto 32px; } }
    @media(max-width: 600px){ .page-sidebar { max-width: 100%; margin: 0 0 24px; } }
    .sidebar-cta {
      background: var(--blue);
      border-radius: 18px;
      padding: 32px 28px;
      color: white;
      margin-bottom: 20px;
    }
    .sidebar-cta h3 { font-size: 1.2rem; font-weight: 800; margin-bottom: 10px; }
    .sidebar-cta p { font-size: 14px; opacity: .88; margin-bottom: 24px; line-height: 1.6; }
    .sidebar-phone { display: block; background: var(--orange); color: white; font-weight: 800; font-size: 1.1rem; text-align: center; padding: 16px; border-radius: 10px; text-decoration: none; margin-bottom: 12px; box-shadow: 0 4px 16px rgba(232,113,34,.4); transition: all .2s; }
    .sidebar-phone:hover { background: var(--orange-dark); color: white; transform: translateY(-1px); }
    .sidebar-link { display: block; background: rgba(255,255,255,.15); border: 1px solid rgba(255,255,255,.3); color: white; font-weight: 600; font-size: 14px; text-align: center; padding: 13px; border-radius: 10px; text-decoration: none; transition: all .2s; }
    .sidebar-link:hover { background: rgba(255,255,255,.25); color: white; }
    .sidebar-bullets { list-style: none; margin: 20px 0 0; padding: 0; border-top: 1px solid rgba(255,255,255,.2); padding-top: 20px; }
    .sidebar-bullets li { font-size: 13.5px; color: rgba(255,255,255,.88); padding: 5px 0 5px 20px; position: relative; }
    .sidebar-bullets li::before { content: "✓"; position: absolute; left: 0; font-weight: 800; color: rgba(255,255,255,.7); }

    .sidebar-info { background: var(--gray-light); border-radius: 14px; padding: 24px; border: 1px solid var(--border); }
    .sidebar-info h4 { font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 14px; text-transform: uppercase; letter-spacing: 1px; }
    .sidebar-info a { display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--blue-dark); text-decoration: none; font-weight: 600; padding: 7px 0; border-bottom: 1px solid var(--border); }
    .sidebar-info a:last-child { border: none; }
    .sidebar-info a:hover { color: var(--orange); }

    /* BOTTOM CTA */
    .bottom-cta { background: var(--orange); padding: 72px 0; text-align: center; position: relative; overflow: hidden; }
    .bottom-cta::before { content: ''; position: absolute; top: -50%; right: -5%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(255,255,255,.1) 0%, transparent 60%); }
    .bottom-cta h2 { font-size: clamp(1.8rem, 3.5vw, 2.5rem); font-weight: 900; color: white; margin-bottom: 12px; position: relative; letter-spacing: -.5px; }
    .bottom-cta p { font-size: 17px; color: rgba(255,255,255,.88); margin-bottom: 36px; position: relative; }
    .btn-white { display: inline-flex; align-items: center; gap: 8px; background: white; color: var(--orange); font-weight: 800; font-size: 17px; padding: 18px 48px; border-radius: 8px; text-decoration: none; box-shadow: 0 4px 20px rgba(0,0,0,.15); transition: all .2s; position: relative; }
    .btn-white:hover { background: #1d1d1d; color: white; transform: translateY(-2px); }

    /* FOOTER */
    .site-footer { background: #1d1d1d; color: rgba(255,255,255,.55); padding: 56px 0 28px; }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; padding-bottom: 40px; border-bottom: 1px solid rgba(255,255,255,.1); }
    .footer-grid h4 { color: white; font-size: 14px; font-weight: 700; margin-bottom: 16px; }
    .footer-grid a { color: rgba(255,255,255,.5); text-decoration: none; display: block; font-size: 13.5px; margin-bottom: 8px; transition: color .15s; }
    .footer-grid a:hover { color: var(--blue); }
    .footer-logo { font-size: 20px; font-weight: 900; color: white; margin-bottom: 12px; }
    .footer-logo .accent { color: var(--blue); }
    .footer-desc { font-size: 13.5px; line-height: 1.7; margin-bottom: 20px; }
    .footer-phone { color: var(--orange) !important; font-weight: 700; font-size: 16px !important; }
    .footer-bottom { display: flex; justify-content: space-between; align-items: center; padding-top: 24px; font-size: 13px; flex-wrap: wrap; gap: 8px; }
    .footer-bottom a { color: rgba(255,255,255,.35); font-size: 13px; text-decoration: none; }
    .footer-bottom a:hover { color: var(--blue); }
    @media(max-width: 768px) { .footer-grid { grid-template-columns: 1fr 1fr; } }
    @media(max-width: 480px) { .footer-grid { grid-template-columns: 1fr; } }
  </style>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
</head>
<body>
  <div class="topbar">
    <div class="container">
      <div class="topbar-inner">
        <span class="topbar-left">📍 Your Local Wichita Cash Home Buyer</span>
        <a href="tel:3163683344">Call or Text Us (316) 368-3344</a>
      </div>
    </div>
  </div>

  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo">Jacob<span class="accent">Buys</span>YourHouse<span class="com">.com</span></a>
      <nav class="site-nav">
        <a href="/about">About Jacob</a>
        <a href="/how-it-works">How It Works</a>
        <a href="/areas">Areas We Serve</a>
        <a href="/blog">Blog</a>
        <a href="/contact" class="btn-nav">Get Your Offer →</a>
      </nav>
    </div>
  </header>

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="page-hero-bg" style={`background-image: url('${heroImage}')`}></div>
    <div class="container page-hero-content">
      {breadcrumb && (
        <div class="breadcrumb-row">
          <a href="/">Home</a>
          <span class="breadcrumb-sep">›</span>
          {breadcrumbHref ? <a href={breadcrumbHref}>{breadcrumb}</a> : <span>{breadcrumb}</span>}
          <span class="breadcrumb-sep">›</span>
          <span style="color:rgba(255,255,255,.9)">{heroTitle}</span>
        </div>
      )}
      <h1>{heroTitle}</h1>
      <p>{heroSub}</p>
      <div class="page-hero-cta">
        <a href="tel:3163683344" class="btn-primary">📞 Call (316) 368-3344</a>
        <a href="/contact" class="btn-ghost">Get a Cash Offer →</a>
      </div>
    </div>
  </section>

  <!-- TRUST STRIP -->
  <div class="trust-strip">
    <div class="container">
      <div class="trust-strip-inner">
        <div class="trust-item"><span class="trust-icon">⚡</span><div class="trust-text"><div class="label">Offer in 24 Hours</div><div class="sub">Based on real market data</div></div></div>
        <div class="trust-item"><span class="trust-icon">🗓</span><div class="trust-text"><div class="label">Close in 7 Days</div><div class="sub">Or on your schedule</div></div></div>
        <div class="trust-item"><span class="trust-icon">💰</span><div class="trust-text"><div class="label">Zero Fees</div><div class="sub">No commissions, we pay costs</div></div></div>
        <div class="trust-item"><span class="trust-icon">🏠</span><div class="trust-text"><div class="label">Any Condition</div><div class="sub">No repairs needed</div></div></div>
      </div>
    </div>
  </div>

  <!-- MAIN BODY -->
  <div class="page-body">
    <div class="container">
      <div class="page-layout">

        <!-- CONTENT -->
        <div class="page-content">
          <slot />
        </div>

        <!-- SIDEBAR -->
        <aside class="page-sidebar">
          <LeadForm />
          <div class="sidebar-info">
            <h4>Situations We Help</h4>
            <a href="/sell/foreclosure">🏚 Facing Foreclosure</a>
            <a href="/sell/inherited-house">📋 Inherited Property</a>
            <a href="/sell/divorce">⚖️ Divorce</a>
            <a href="/sell/as-is">🔨 Sell As-Is</a>
            <a href="/sell/rental-property">🔑 Tired Landlord</a>
            <a href="/sell/behind-on-taxes">📃 Tax Problems</a>
            <a href="/sell/probate">⚖️ Probate</a>
          </div>
        </aside>

      </div>
    </div>
  </div>

  <!-- BOTTOM CTA -->
  <section class="bottom-cta">
    <div class="container">
      <h2>Ready to Get Your Cash Offer?</h2>
      <p>Local buyer. Straight answers. Fast close. No hassle.</p>
      <a href="tel:3163683344" class="btn-white">📞 Call (316) 368-3344</a>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div>
          <div class="footer-logo">Jacob<span class="accent">Buys</span>YourHouse</div>
          <p class="footer-desc">Local cash home buyer serving Wichita, KS and surrounding communities. No fees, no repairs, no hassle.</p>
          <a href="tel:3163683344" class="footer-phone">(316) 368-3344</a>
        </div>
        <div>
          <h4>Situations</h4>
          <a href="/sell/inherited-house">Inherited Property</a>
          <a href="/sell/foreclosure">Stop Foreclosure</a>
          <a href="/sell/divorce">Divorce</a>
          <a href="/sell/as-is">Sell As-Is</a>
          <a href="/sell/rental-property">Tired Landlord</a>
          <a href="/sell/behind-on-taxes">Tax Problems</a>
          <a href="/sell/probate">Probate</a>
        </div>
        <div>
          <h4>Areas</h4>
          <a href="/areas/wichita">Wichita</a>
          <a href="/areas/derby">Derby</a>
          <a href="/areas/mulvane">Mulvane</a>
          <a href="/areas/haysville">Haysville</a>
          <a href="/areas/andover">Andover</a>
          <a href="/areas/augusta">Augusta</a>
          <a href="/areas/el-dorado">El Dorado</a>
        </div>
        <div>
          <h4>Company</h4>
          <a href="/how-it-works">How It Works</a>
          <a href="/about">About Jacob</a>
          <a href="/faq">FAQ</a>
          <a href="/blog">Blog</a>
          <a href="/contact">Contact</a>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© {new Date().getFullYear()} Jacob Buys Your House · Wichita, KS</span>
        <a href="/privacy">Privacy Policy</a>
      </div>
    </div>
  </footer>
</body>
</html>
